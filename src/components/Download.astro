---
---

<section id="download" class="relative py-24 md:py-32">
  <div class="max-w-6xl mx-auto px-6">
    <div class="relative glass-card overflow-hidden">
      <!-- Background glow -->
      <div class="absolute inset-0 pointer-events-none">
        <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[300px] h-[300px] bg-accent/10 rounded-full blur-[80px]"></div>
      </div>

      <div class="relative px-8 py-16 md:px-16 md:py-20 text-center">
        <!-- macOS Icon -->
        <div class="inline-flex items-center justify-center w-16 h-16 rounded-2xl bg-bg-tertiary border border-border mb-8">
          <svg class="w-9 h-9 text-text-primary" viewBox="0 0 24 24" fill="currentColor">
            <path d="M18.71 19.5c-.83 1.24-1.71 2.45-3.05 2.47-1.34.03-1.77-.79-3.29-.79-1.53 0-2 .77-3.27.82-1.31.05-2.3-1.32-3.14-2.53C4.25 17 2.94 12.45 4.7 9.39c.87-1.52 2.43-2.48 4.12-2.51 1.28-.02 2.5.87 3.29.87.78 0 2.26-1.07 3.8-.91.65.03 2.47.26 3.64 1.98-.09.06-2.17 1.28-2.15 3.81.03 3.02 2.65 4.03 2.68 4.04-.03.07-.42 1.44-1.38 2.83M13 3.5c.73-.83 1.94-1.46 2.94-1.5.13 1.17-.34 2.35-1.04 3.19-.69.85-1.83 1.51-2.95 1.42-.15-1.15.41-2.35 1.05-3.11z"/>
          </svg>
        </div>

        <h2 class="text-3xl md:text-4xl font-bold tracking-tight mb-4">
          Ready to take control of your windows?
        </h2>
        <p class="text-text-secondary text-lg max-w-lg mx-auto mb-10">
          Download ClickFit for free and start managing your macOS windows the way they should be.
        </p>

        <!-- Download Button -->
        <a
          href="#"
          class="inline-flex items-center gap-3 bg-accent hover:bg-accent-hover text-white font-medium px-10 py-4 rounded-xl transition-all shadow-lg shadow-accent-glow hover:shadow-xl hover:shadow-accent-glow text-lg"
        >
          <svg class="w-6 h-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M21 15v4a2 2 0 01-2 2H5a2 2 0 01-2-2v-4M7 10l5 5 5-5M12 15V3"/>
          </svg>
          Download for macOS
        </a>

        <!-- System Requirements -->
        <div class="mt-8 flex flex-col sm:flex-row items-center justify-center gap-6 text-sm text-text-secondary/60">
          <div class="flex items-center gap-2">
            <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M12 2C6.477 2 2 6.477 2 12s4.477 10 10 10 10-4.477 10-10S17.523 2 12 2z"/>
              <path d="M8 12l3 3 5-5"/>
            </svg>
            macOS 14 Sonoma or later
          </div>
          <div class="flex items-center gap-2">
            <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M12 2C6.477 2 2 6.477 2 12s4.477 10 10 10 10-4.477 10-10S17.523 2 12 2z"/>
              <path d="M8 12l3 3 5-5"/>
            </svg>
            Apple Silicon &amp; Intel
          </div>
          <div class="flex items-center gap-2">
            <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M12 2C6.477 2 2 6.477 2 12s4.477 10 10 10 10-4.477 10-10S17.523 2 12 2z"/>
              <path d="M8 12l3 3 5-5"/>
            </svg>
            Free to use
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
