---
---

<section id="pricing" class="relative py-16 md:py-20">
  <div class="max-w-6xl mx-auto px-6">

    <!-- Section header -->
    <div class="text-center mb-16" data-animate="fade-up">
      <h2 class="text-3xl md:text-5xl font-bold tracking-tight mb-4">
        Simple pricing
      </h2>
      <p class="text-text-secondary text-lg max-w-lg mx-auto">
        Choose the plan that works for you.
      </p>
    </div>

    <!-- Pricing cards -->
    <div class="grid md:grid-cols-3 gap-6" data-animate="scale-in">

      <!-- Free plan -->
      <div class="glass-card p-8 text-center relative overflow-hidden flex flex-col">
        <div class="absolute top-0 left-1/2 -translate-x-1/2 w-48 h-48 bg-black/5 dark:bg-white/5 rounded-full blur-[60px] pointer-events-none"></div>

        <div class="relative flex flex-col flex-1">
          <span class="inline-block text-xs font-semibold tracking-widest uppercase text-text-secondary mb-6 px-3 py-1 rounded-full border border-black/10 dark:border-white/10 bg-black/5 dark:bg-white/5">
            Free
          </span>

          <div class="mb-2">
            <span class="text-5xl font-bold">$0</span>
            <span class="text-text-secondary ml-1">/ forever</span>
          </div>
          <p class="text-text-secondary/60 text-sm mb-8">Basic window management</p>

          <ul class="text-left space-y-3 mb-8 text-sm flex-1">
            <li class="flex items-center gap-3">
              <svg class="w-4 h-4 text-accent shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
                <path d="M20 6L9 17l-5-5"/>
              </svg>
              <span>Move windows</span>
            </li>
            <li class="flex items-center gap-3">
              <svg class="w-4 h-4 text-accent shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
                <path d="M20 6L9 17l-5-5"/>
              </svg>
              <span>Resize windows</span>
            </li>
            <li class="flex items-center gap-3 opacity-35">
              <svg class="w-4 h-4 shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
                <path d="M18 6L6 18M6 6l12 12"/>
              </svg>
              <span>Snapping & tiling</span>
            </li>
            <li class="flex items-center gap-3 opacity-35">
              <svg class="w-4 h-4 shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
                <path d="M18 6L6 18M6 6l12 12"/>
              </svg>
              <span>Keyboard shortcuts</span>
            </li>
            <li class="flex items-center gap-3 opacity-35">
              <svg class="w-4 h-4 shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
                <path d="M18 6L6 18M6 6l12 12"/>
              </svg>
              <span>Layouts & actions</span>
            </li>
          </ul>

          <a
            href="#download"
            class="w-full inline-flex items-center justify-center gap-2 bg-black/8 hover:bg-black/12 dark:bg-white/10 dark:hover:bg-white/15 text-gray-900 dark:text-white font-medium px-8 py-4 rounded-xl transition-all text-base cursor-pointer no-underline border border-black/10 dark:border-white/10"
          >
            Download
          </a>
          <!-- spacer to match "Secure checkout" height on other cards -->
          <p class="text-xs mt-4 invisible">placeholder</p>
        </div>
      </div>

      <!-- Yearly plan -->
      <div class="glass-card p-8 text-center relative overflow-hidden flex flex-col">
        <div class="absolute top-0 left-1/2 -translate-x-1/2 w-48 h-48 bg-accent/5 rounded-full blur-[60px] pointer-events-none"></div>

        <div class="relative flex flex-col flex-1">
          <span class="inline-block text-xs font-semibold tracking-widest uppercase text-text-secondary mb-6 px-3 py-1 rounded-full border border-black/10 dark:border-white/10 bg-black/5 dark:bg-white/5">
            Yearly
          </span>

          <div class="mb-2">
            <span class="text-5xl font-bold">$4.90</span>
            <span class="text-text-secondary ml-1">/ year</span>
          </div>
          <p class="text-text-secondary/60 text-sm mb-8">14-day free trial included</p>

          <ul class="text-left space-y-3 mb-8 text-sm flex-1">
            <li class="flex items-center gap-3">
              <svg class="w-4 h-4 text-accent shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
                <path d="M20 6L9 17l-5-5"/>
              </svg>
              <span>All window management features</span>
            </li>
            <li class="flex items-center gap-3">
              <svg class="w-4 h-4 text-accent shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
                <path d="M20 6L9 17l-5-5"/>
              </svg>
              <span>Free updates while subscribed</span>
            </li>
            <li class="flex items-center gap-3">
              <svg class="w-4 h-4 text-accent shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
                <path d="M20 6L9 17l-5-5"/>
              </svg>
              <span>14-day free trial</span>
            </li>
            <li class="flex items-center gap-3">
              <svg class="w-4 h-4 text-accent shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
                <path d="M20 6L9 17l-5-5"/>
              </svg>
              <span>1 device at a time</span>
            </li>
          </ul>

          <a
            href="https://clickfit.lemonsqueezy.com/checkout/buy/e8f0c276-2125-494b-940f-27b6eb9a31fc"
            class="lemonsqueezy-button w-full inline-flex items-center justify-center gap-2 bg-black/8 hover:bg-black/12 dark:bg-white/10 dark:hover:bg-white/15 text-gray-900 dark:text-white font-medium px-8 py-4 rounded-xl transition-all text-base cursor-pointer no-underline border border-black/10 dark:border-white/10"
          >
            Buy Now
          </a>

          <p class="text-xs text-text-secondary/50 mt-4">
            Secure checkout via LemonSqueezy
          </p>
        </div>
      </div>

      <!-- Lifetime plan -->
      <div class="glass-card p-8 text-center relative overflow-hidden ring-1 ring-accent/30 flex flex-col">
        <div class="absolute top-0 left-1/2 -translate-x-1/2 w-48 h-48 bg-accent/10 rounded-full blur-[60px] pointer-events-none"></div>

        <div class="relative flex flex-col flex-1">
          <span class="inline-block text-xs font-semibold tracking-widest uppercase text-accent mb-6 px-3 py-1 rounded-full border border-accent/30 bg-accent/5">
            Lifetime
          </span>

          <div class="mb-2">
            <span class="text-5xl font-bold">$8.9</span>
            <span class="text-text-secondary ml-1">/ once</span>
          </div>
          <p class="text-text-secondary/60 text-sm mb-8">Pay once, own it forever</p>

          <ul class="text-left space-y-3 mb-8 text-sm flex-1">
            <li class="flex items-center gap-3">
              <svg class="w-4 h-4 text-accent shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
                <path d="M20 6L9 17l-5-5"/>
              </svg>
              <span>All window management features</span>
            </li>
            <li class="flex items-center gap-3">
              <svg class="w-4 h-4 text-accent shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
                <path d="M20 6L9 17l-5-5"/>
              </svg>
              <span>Free updates, forever</span>
            </li>
            <li class="flex items-center gap-3">
              <svg class="w-4 h-4 text-accent shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
                <path d="M20 6L9 17l-5-5"/>
              </svg>
              <span>1 license — up to 3 devices</span>
            </li>
          </ul>

          <a
            href="https://clickfit.lemonsqueezy.com/checkout/buy/fff51e31-44e0-4f2d-a11d-57043816a52a"
            class="lemonsqueezy-button w-full inline-flex items-center justify-center gap-2 bg-accent hover:bg-accent-hover text-white font-medium px-8 py-4 rounded-xl transition-all shadow-lg shadow-accent-glow hover:shadow-xl hover:shadow-accent-glow text-base cursor-pointer no-underline"
          >
            <svg class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M12 2C6.477 2 2 6.477 2 12s4.477 10 10 10 10-4.477 10-10S17.523 2 12 2z"/>
              <path d="M8 12l3 3 5-5"/>
            </svg>
            Buy Now
          </a>

          <p class="text-xs text-text-secondary/50 mt-4">
            Secure checkout via LemonSqueezy
          </p>
        </div>
      </div>

    </div>

  </div>
</section>

<script src="https://assets.lemonsqueezy.com/lemon.js" defer></script>
