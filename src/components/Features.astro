---
const tier2Features = [
  {
    icon: `<svg class="w-8 h-8" viewBox="0 0 32 32" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="4" y="6" width="24" height="20" rx="3"/><path d="M10 16h2M14 16h2M18 16h2M12 12h2M16 12h2M20 12h2" stroke-linecap="round"/><rect x="9" y="21" width="14" height="2" rx="1"/></svg>`,
    title: 'Keyboard Shortcuts',
    description: 'Customizable global hotkeys for tiling, centering, maximizing, layouts, and cross-display moves.',
  },
  {
    icon: `<svg class="w-8 h-8" viewBox="0 0 32 32" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="4" y="4" width="24" height="24" rx="2"/><path d="M4 16h24M16 4v24M4 10h24M4 22h24"/></svg>`,
    title: 'Predefined Layouts',
    description: 'Instantly arrange windows into 9 layout presets: columns, rows, grids, and split ratios.',
  },
  {
    icon: `<svg class="w-8 h-8" viewBox="0 0 32 32" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="2" y="8" width="12" height="9" rx="2"/><rect x="18" y="8" width="12" height="9" rx="2"/><path d="M14 12.5h4" stroke-linecap="round"/><path d="M8 20v3M24 20v3M6 23h4M22 23h4"/></svg>`,
    title: 'Multi-Monitor & Spaces',
    description: 'Move windows between displays and virtual desktops with a keystroke.',
  },
  {
    icon: `<svg class="w-8 h-8" viewBox="0 0 32 32" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M17 4L7 18h9l-1 10 10-14h-9l1-10z"/></svg>`,
    title: 'Lightweight & Fast',
    description: 'Native Swift with vsync-aligned updates. Under 20MB, minimal memory footprint.',
  },
  {
    icon: `<svg class="w-8 h-8" viewBox="0 0 32 32" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="4" y="4" width="11" height="11" rx="2"/><rect x="17" y="4" width="11" height="11" rx="2"/><rect x="4" y="17" width="11" height="11" rx="2"/><rect x="17" y="17" width="11" height="11" rx="2"/><path d="M15 10h2M15 22h2" stroke-linecap="round" stroke-dasharray="2 2"/></svg>`,
    title: 'Adaptive Tiling',
    description: 'Tile zones detect anchored neighbors and expand to fill remaining space automatically.',
  },
  {
    icon: `<svg class="w-8 h-8" viewBox="0 0 32 32" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="4" y="6" width="10" height="20" rx="2"/><rect x="18" y="6" width="10" height="20" rx="2"/><path d="M14 16h4M14 16l2-2M14 16l2 2M18 16l-2-2M18 16l-2 2" stroke-linecap="round" stroke-linejoin="round"/></svg>`,
    title: 'Coupled Window Resizing',
    description: 'Grab a shared border — both windows resize together in perfect sync.',
  },
];
---

<section id="features" class="relative py-16 md:py-20">
  <!-- Ambient glow -->
  <div class="absolute inset-0 pointer-events-none">
    <div class="absolute top-1/4 right-0 w-[400px] h-[400px] bg-accent/5 rounded-full blur-[120px]"></div>
  </div>

  <div class="relative max-w-6xl mx-auto px-6">
    <!-- Section Header -->
    <div class="text-center mb-20" data-animate="fade-up">
      <p class="text-accent text-sm font-medium tracking-wide uppercase mb-3">Features</p>
      <h2 class="text-4xl md:text-5xl font-bold tracking-tight mb-4">
        Everything you need to manage windows
      </h2>
      <p class="text-text-secondary text-lg max-w-xl mx-auto">
        Powerful features packed into a lightweight, native macOS app.
      </p>
    </div>

    <!-- ═══ TIER 1: Three big feature cards (zigzag) ═══ -->
    <div class="space-y-16 md:space-y-24 mb-24">

      <!-- Feature 1: Mouse Move & Resize (text left, visual right) -->
      <div class="glass-card overflow-hidden" data-animate="fade-up">
        <div class="grid grid-cols-1 md:grid-cols-2 gap-0">
          <div class="p-8 md:p-12 flex flex-col justify-center">
            <h3 class="text-2xl md:text-3xl font-bold mb-4">Mouse Move & Resize</h3>
            <p class="text-text-secondary leading-relaxed mb-6">
              Hold a modifier key and left-click drag to move any window from anywhere. Right-click drag to resize from any position — no need to find tiny edges or title bars.
            </p>
            <div class="flex items-center gap-2">
              <span class="inline-flex items-center px-3 py-1.5 rounded-lg text-xs font-semibold font-mono-badge" style="background:var(--surface-glass); border:1px solid var(--border);">
                Modifier + Click
              </span>
            </div>
          </div>
          <div class="relative flex items-center justify-center p-8 md:p-12 min-h-[200px]" data-animate="fade-in">
            <!-- Move & Resize SVG illustration -->
            <svg class="w-full max-w-[260px]" viewBox="0 0 200 160" fill="none" xmlns="http://www.w3.org/2000/svg">
              <!-- Window -->
              <rect x="30" y="20" width="120" height="90" rx="10" stroke="currentColor" stroke-width="1.5" fill="var(--accent)" fill-opacity="0.08"/>
              <rect x="30" y="20" width="120" height="24" rx="10" stroke="currentColor" stroke-width="1.5" fill="var(--accent)" fill-opacity="0.05"/>
              <circle cx="44" cy="32" r="3" fill="#FF5F57"/>
              <circle cx="54" cy="32" r="3" fill="#FEBC2E"/>
              <circle cx="64" cy="32" r="3" fill="#28C840"/>
              <!-- Content lines -->
              <line x1="42" y1="56" x2="100" y2="56" stroke="currentColor" stroke-width="1" opacity="0.15" stroke-linecap="round"/>
              <line x1="42" y1="66" x2="85" y2="66" stroke="currentColor" stroke-width="1" opacity="0.15" stroke-linecap="round"/>
              <line x1="42" y1="76" x2="110" y2="76" stroke="currentColor" stroke-width="1" opacity="0.15" stroke-linecap="round"/>
              <line x1="42" y1="86" x2="75" y2="86" stroke="currentColor" stroke-width="1" opacity="0.15" stroke-linecap="round"/>
              <!-- Move arrows -->
              <g opacity="0.6">
                <path d="M170 80L185 65" stroke="var(--accent)" stroke-width="2" stroke-linecap="round"/>
                <path d="M180 65L185 65L185 70" stroke="var(--accent)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
              </g>
              <!-- Cursor -->
              <path d="M155 95l-1-15 10 10-6 1-3 6z" fill="white" stroke="currentColor" stroke-width="0.75"/>
              <!-- Resize indicator -->
              <g opacity="0.5">
                <path d="M150 110l-8-8M150 110l-12 0M150 110l0-12" stroke="var(--accent)" stroke-width="1.5" stroke-linecap="round"/>
              </g>
            </svg>
          </div>
        </div>
      </div>

      <!-- Feature 2: Edge Snapping & Tiling (visual left, text right) -->
      <div class="glass-card overflow-hidden" data-animate="fade-up">
        <div class="grid grid-cols-1 md:grid-cols-2 gap-0">
          <div class="relative flex items-center justify-center p-8 md:p-12 min-h-[200px] order-2 md:order-1" data-animate="fade-in">
            <!-- Snap & Tile SVG illustration -->
            <svg class="w-full max-w-[260px]" viewBox="0 0 200 160" fill="none" xmlns="http://www.w3.org/2000/svg">
              <!-- Screen outline -->
              <rect x="10" y="10" width="180" height="130" rx="8" stroke="currentColor" stroke-width="1.5" opacity="0.3"/>
              <!-- Left half tile overlay -->
              <rect x="14" y="14" width="86" height="122" rx="6" fill="var(--accent)" fill-opacity="0.12" stroke="var(--accent)" stroke-width="1.5" stroke-dasharray="4 3"/>
              <!-- Window being dragged -->
              <rect x="20" y="20" width="76" height="55" rx="8" stroke="currentColor" stroke-width="1.5" fill="var(--accent)" fill-opacity="0.06"/>
              <rect x="20" y="20" width="76" height="18" rx="8" stroke="currentColor" stroke-width="1" fill="var(--accent)" fill-opacity="0.04"/>
              <circle cx="30" cy="29" r="2.5" fill="#FF5F57"/>
              <circle cx="38" cy="29" r="2.5" fill="#FEBC2E"/>
              <circle cx="46" cy="29" r="2.5" fill="#28C840"/>
              <!-- Edge glow line -->
              <line x1="12" y1="14" x2="12" y2="136" stroke="var(--accent)" stroke-width="2" opacity="0.6"/>
              <!-- Arrow showing drag direction -->
              <path d="M120 50L40 50" stroke="var(--accent)" stroke-width="1.5" stroke-linecap="round" opacity="0.4"/>
              <path d="M46 46L40 50L46 54" stroke="var(--accent)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" opacity="0.4"/>
              <!-- Cursor near edge -->
              <path d="M25 55l-1-12 8 8-5 1-2 5z" fill="white" stroke="currentColor" stroke-width="0.5"/>
            </svg>
          </div>
          <div class="p-8 md:p-12 flex flex-col justify-center order-1 md:order-2">
            <h3 class="text-2xl md:text-3xl font-bold mb-4">Edge Snapping & Tiling</h3>
            <p class="text-text-secondary leading-relaxed mb-6">
              Drag windows to screen edges to snap into tiled positions. 9 tile zones — halves, quarters, and full screen — with visual overlay previews before you drop.
            </p>
            <div class="flex items-center gap-2">
              <span class="inline-flex items-center px-3 py-1.5 rounded-lg text-xs font-semibold font-mono-badge" style="background:var(--surface-glass); border:1px solid var(--border);">
                Drag to Edge
              </span>
            </div>
          </div>
        </div>
      </div>

      <!-- Feature 3: Smart Snap & Coupled Resize (text left, visual right) -->
      <div class="glass-card overflow-hidden" data-animate="fade-up">
        <div class="grid grid-cols-1 md:grid-cols-2 gap-0">
          <div class="p-8 md:p-12 flex flex-col justify-center">
            <h3 class="text-2xl md:text-3xl font-bold mb-4">Smart Snap & Coupled Resize</h3>
            <p class="text-text-secondary leading-relaxed mb-6">
              Windows automatically snap to each other's edges. Grab a shared border and both windows resize together in sync — your layout stays perfectly aligned.
            </p>
            <div class="flex items-center gap-2">
              <span class="inline-flex items-center px-3 py-1.5 rounded-lg text-xs font-semibold font-mono-badge" style="background:var(--surface-glass); border:1px solid var(--border);">
                Drag Shared Border
              </span>
            </div>
          </div>
          <div class="relative flex items-center justify-center p-8 md:p-12 min-h-[200px]" data-animate="fade-in">
            <!-- Coupled Resize SVG illustration -->
            <svg class="w-full max-w-[260px]" viewBox="0 0 200 160" fill="none" xmlns="http://www.w3.org/2000/svg">
              <!-- Left window -->
              <rect x="10" y="15" width="82" height="120" rx="8" stroke="currentColor" stroke-width="1.5" fill="var(--accent)" fill-opacity="0.06"/>
              <rect x="10" y="15" width="82" height="20" rx="8" stroke="currentColor" stroke-width="1" fill="var(--accent)" fill-opacity="0.04"/>
              <circle cx="20" cy="25" r="2.5" fill="#FF5F57"/>
              <circle cx="28" cy="25" r="2.5" fill="#FEBC2E"/>
              <circle cx="36" cy="25" r="2.5" fill="#28C840"/>
              <!-- Right window -->
              <rect x="96" y="15" width="94" height="120" rx="8" stroke="currentColor" stroke-width="1.5" fill="var(--accent)" fill-opacity="0.06"/>
              <rect x="96" y="15" width="94" height="20" rx="8" stroke="currentColor" stroke-width="1" fill="var(--accent)" fill-opacity="0.04"/>
              <circle cx="106" cy="25" r="2.5" fill="#FF5F57"/>
              <circle cx="114" cy="25" r="2.5" fill="#FEBC2E"/>
              <circle cx="122" cy="25" r="2.5" fill="#28C840"/>
              <!-- Shared border with glow -->
              <line x1="93" y1="20" x2="93" y2="130" stroke="var(--accent)" stroke-width="2"/>
              <!-- Bidirectional arrow -->
              <g opacity="0.8">
                <path d="M78 75h30" stroke="var(--accent)" stroke-width="1.5" stroke-linecap="round"/>
                <path d="M82 71l-4 4 4 4" stroke="var(--accent)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                <path d="M104 71l4 4-4 4" stroke="var(--accent)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
              </g>
              <!-- Content lines left -->
              <line x1="22" y1="45" x2="65" y2="45" stroke="currentColor" stroke-width="1" opacity="0.12" stroke-linecap="round"/>
              <line x1="22" y1="55" x2="55" y2="55" stroke="currentColor" stroke-width="1" opacity="0.12" stroke-linecap="round"/>
              <!-- Content lines right -->
              <line x1="108" y1="45" x2="160" y2="45" stroke="currentColor" stroke-width="1" opacity="0.12" stroke-linecap="round"/>
              <line x1="108" y1="55" x2="145" y2="55" stroke="currentColor" stroke-width="1" opacity="0.12" stroke-linecap="round"/>
            </svg>
          </div>
        </div>
      </div>
    </div>

    <!-- ═══ TIER 2: Feature grid (7 cards) ═══ -->
    <div class="text-center mb-12" data-animate="fade-up">
      <h3 class="text-3xl md:text-4xl font-bold tracking-tight">And much more</h3>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5" data-animate="stagger">
      {tier2Features.map((feature) => (
        <div class="group relative p-6 glass-card hover:border-accent/30 transition-all duration-300 hover:-translate-y-0.5">
          <div class="w-14 h-14 rounded-xl flex items-center justify-center mb-4 transition-colors" style="background:linear-gradient(135deg, rgba(166,179,204,0.1), rgba(139,159,204,0.1));">
            <span class="text-accent">
              <Fragment set:html={feature.icon} />
            </span>
          </div>
          <h3 class="text-lg font-semibold mb-2">{feature.title}</h3>
          <p class="text-text-secondary text-sm leading-relaxed">{feature.description}</p>
        </div>
      ))}
    </div>
  </div>
</section>
