---
---

<section id="features" class="relative py-16 md:py-20">
  <!-- Ambient glow -->
  <div class="absolute inset-0 pointer-events-none">
    <div class="absolute top-1/4 right-0 w-[400px] h-[400px] bg-accent/5 rounded-full blur-[120px]"></div>
    <div class="absolute bottom-1/3 left-0 w-[300px] h-[300px] bg-accent/5 rounded-full blur-[100px]"></div>
  </div>

  <div class="relative max-w-6xl mx-auto px-6">
    <!-- Section Header -->
    <div class="text-center mb-14" data-animate="fade-up">
      <p class="text-accent text-sm font-medium tracking-wide uppercase mb-3">Features</p>
      <h2 class="text-4xl md:text-5xl font-bold tracking-tight mb-4">
        Fast with the mouse.<br class="hidden sm:block" /> Faster with hotkeys.
      </h2>
      <p class="text-text-secondary text-lg max-w-2xl mx-auto">
        One modifier key gets you started. Snap, tiling, layouts, and multi-display moves are there when you need them.
      </p>
    </div>

    <!-- ═══ Bento Grid ═══ -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-4" data-animate="stagger">

      <!-- ── Row 1: Modifier Gestures (wide) + One-Click Actions (narrow) ── -->

      <div class="md:col-span-2 glass-card overflow-hidden hover:border-accent/30 transition-all duration-300">
        <div class="flex flex-col md:flex-row md:items-center gap-2">
          <div class="flex-1 p-6 md:p-8">
            <h3 class="text-xl md:text-2xl font-bold mb-3">Modifier Gestures</h3>
            <p class="text-text-secondary text-sm leading-relaxed mb-4">
              Hold your modifier and drag from anywhere to move a window. Right-drag to resize. No title bars needed.
            </p>
            <div class="flex flex-wrap items-center gap-2">
              <span class="inline-flex items-center px-2.5 py-1 rounded-md text-xs font-semibold font-mono-badge" style="background:var(--surface-glass); border:1px solid var(--border);">⌘ + Drag</span>
              <span class="inline-flex items-center px-2.5 py-1 rounded-md text-xs font-semibold font-mono-badge" style="background:var(--surface-glass); border:1px solid var(--border);">Right-drag resize</span>
            </div>
          </div>
          <div class="hidden md:flex items-center justify-center pr-6 shrink-0">
            <svg class="w-36 h-28" viewBox="0 0 180 130" fill="none" xmlns="http://www.w3.org/2000/svg">
              <rect x="20" y="10" width="100" height="75" rx="8" stroke="currentColor" stroke-width="1.5" fill="var(--accent)" fill-opacity="0.08"/>
              <rect x="20" y="10" width="100" height="20" rx="8" stroke="currentColor" stroke-width="1.5" fill="var(--accent)" fill-opacity="0.05"/>
              <circle cx="32" cy="20" r="2.5" fill="#FF5F57"/><circle cx="40" cy="20" r="2.5" fill="#FEBC2E"/><circle cx="48" cy="20" r="2.5" fill="#28C840"/>
              <line x1="32" y1="40" x2="80" y2="40" stroke="currentColor" stroke-width="1" opacity="0.15" stroke-linecap="round"/>
              <line x1="32" y1="48" x2="68" y2="48" stroke="currentColor" stroke-width="1" opacity="0.15" stroke-linecap="round"/>
              <line x1="32" y1="56" x2="90" y2="56" stroke="currentColor" stroke-width="1" opacity="0.15" stroke-linecap="round"/>
              <g opacity="0.6">
                <path d="M140 60L155 45" stroke="var(--accent)" stroke-width="2" stroke-linecap="round"/>
                <path d="M150 45L155 45L155 50" stroke="var(--accent)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
              </g>
              <path d="M128 78l-1-12 8 8-5 1-2 5z" fill="white" stroke="currentColor" stroke-width="0.75"/>
              <g opacity="0.5">
                <path d="M122 95l-6-6M122 95l-9 0M122 95l0-9" stroke="var(--accent)" stroke-width="1.5" stroke-linecap="round"/>
              </g>
            </svg>
          </div>
        </div>
      </div>

      <div class="glass-card p-6 hover:border-accent/30 transition-all duration-300 flex flex-col">
        <div class="w-11 h-11 rounded-xl flex items-center justify-center mb-4" style="background:linear-gradient(135deg, rgba(166,179,204,0.1), rgba(139,159,204,0.1));">
          <span class="text-accent">
            <svg class="w-6 h-6" viewBox="0 0 24 24" fill="none" stroke="var(--accent)" stroke-width="1.5">
              <circle cx="12" cy="12" r="7" stroke-dasharray="3 2" opacity="0.5"/>
              <circle cx="12" cy="12" r="2.5" fill="var(--accent)" fill-opacity="0.3"/>
              <path d="M12 3v2M12 19v2M3 12h2M19 12h2" stroke-linecap="round" opacity="0.35"/>
            </svg>
          </span>
        </div>
        <h3 class="text-lg font-semibold mb-2">One-Click Actions</h3>
        <p class="text-text-secondary text-sm leading-relaxed">Double-click to center. Double-right-click to maximize. Combo-click for almost-maximize.</p>
      </div>

      <!-- ── Row 2: Smart Snap + Coupled Resize + 9 Tile Zones ── -->

      <div class="glass-card p-6 hover:border-accent/30 transition-all duration-300 flex flex-col">
        <div class="w-11 h-11 rounded-xl flex items-center justify-center mb-4" style="background:linear-gradient(135deg, rgba(166,179,204,0.1), rgba(139,159,204,0.1));">
          <span class="text-accent">
            <svg class="w-6 h-6" viewBox="0 0 24 24" fill="none" stroke="var(--accent)" stroke-width="1.5">
              <rect x="2" y="4" width="8" height="10" rx="2" fill="var(--accent)" fill-opacity="0.08"/>
              <rect x="14" y="7" width="8" height="10" rx="2" fill="var(--accent)" fill-opacity="0.08"/>
              <path d="M10 9h4" stroke-width="2" stroke-linecap="round" stroke-dasharray="1.5 1.5"/>
            </svg>
          </span>
        </div>
        <h3 class="text-lg font-semibold mb-2">Smart Snap</h3>
        <p class="text-text-secondary text-sm leading-relaxed">Windows magnetically align to screen edges and nearby windows.</p>
      </div>

      <div class="glass-card p-6 hover:border-accent/30 transition-all duration-300 flex flex-col">
        <div class="w-11 h-11 rounded-xl flex items-center justify-center mb-4" style="background:linear-gradient(135deg, rgba(166,179,204,0.1), rgba(139,159,204,0.1));">
          <span class="text-accent">
            <svg class="w-6 h-6" viewBox="0 0 24 24" fill="none" stroke="var(--accent)" stroke-width="1.5">
              <rect x="2" y="4" width="8" height="16" rx="2"/>
              <rect x="14" y="4" width="8" height="16" rx="2"/>
              <path d="M10 12h4M10 12l1.5-1.5M10 12l1.5 1.5M14 12l-1.5-1.5M14 12l-1.5 1.5" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </span>
        </div>
        <h3 class="text-lg font-semibold mb-2">Coupled Resize</h3>
        <p class="text-text-secondary text-sm leading-relaxed">Drag a shared border — both windows resize in perfect sync.</p>
      </div>

      <div class="glass-card p-6 hover:border-accent/30 transition-all duration-300 flex flex-col">
        <div class="w-11 h-11 rounded-xl flex items-center justify-center mb-4" style="background:linear-gradient(135deg, rgba(166,179,204,0.1), rgba(139,159,204,0.1));">
          <span class="text-accent">
            <svg class="w-6 h-6" viewBox="0 0 24 24" fill="none" stroke="var(--accent)" stroke-width="1.5">
              <rect x="2" y="2" width="20" height="20" rx="3" opacity="0.3"/>
              <rect x="3" y="3" width="9" height="8" rx="2" fill="var(--accent)" fill-opacity="0.12"/>
              <rect x="12" y="3" width="9" height="8" rx="2" fill="var(--accent)" fill-opacity="0.08"/>
              <rect x="3" y="11" width="9" height="10" rx="2" fill="var(--accent)" fill-opacity="0.08"/>
              <rect x="12" y="11" width="9" height="10" rx="2" fill="var(--accent)" fill-opacity="0.12"/>
            </svg>
          </span>
        </div>
        <h3 class="text-lg font-semibold mb-2">9 Tile Zones</h3>
        <p class="text-text-secondary text-sm leading-relaxed">Halves, quarters, and full screen with a frosted preview overlay.</p>
      </div>

      <!-- ── Row 3: Custom Modifiers (narrow) + Hotkeys & Layouts (wide) ── -->

      <div class="glass-card p-6 hover:border-accent/30 transition-all duration-300 flex flex-col">
        <div class="w-11 h-11 rounded-xl flex items-center justify-center mb-4" style="background:linear-gradient(135deg, rgba(166,179,204,0.1), rgba(139,159,204,0.1));">
          <span class="text-accent">
            <svg class="w-6 h-6" viewBox="0 0 24 24" fill="none" stroke="var(--accent)" stroke-width="1.5">
              <rect x="2" y="6" width="8" height="6" rx="2"/><rect x="12" y="6" width="4" height="6" rx="1.5"/>
              <rect x="18" y="6" width="4" height="6" rx="1.5"/><rect x="4" y="14" width="10" height="5" rx="1.5"/>
              <rect x="16" y="14" width="5" height="5" rx="1.5"/>
            </svg>
          </span>
        </div>
        <h3 class="text-lg font-semibold mb-2">Custom Modifiers</h3>
        <p class="text-text-secondary text-sm leading-relaxed">Use ⌘ ⌥ ⌃ ⇧ in any combination as your trigger key.</p>
      </div>

      <div class="md:col-span-2 glass-card overflow-hidden hover:border-accent/30 transition-all duration-300">
        <div class="flex flex-col md:flex-row md:items-center gap-2">
          <div class="flex-1 p-6 md:p-8">
            <h3 class="text-xl md:text-2xl font-bold mb-3">Hotkeys & Layouts</h3>
            <p class="text-text-secondary text-sm leading-relaxed mb-4">
              27+ global shortcuts. 9 layout presets for 2–4 windows. One key arranges your workspace.
            </p>
            <div class="flex flex-wrap items-center gap-2">
              <span class="inline-flex items-center px-2.5 py-1 rounded-md text-xs font-semibold font-mono-badge" style="background:var(--surface-glass); border:1px solid var(--border);">27+ shortcuts</span>
              <span class="inline-flex items-center px-2.5 py-1 rounded-md text-xs font-semibold font-mono-badge" style="background:var(--surface-glass); border:1px solid var(--border);">9 layouts</span>
            </div>
          </div>
          <div class="hidden md:flex items-center justify-center pr-6 shrink-0">
            <svg class="w-36 h-28" viewBox="0 0 180 130" fill="none" xmlns="http://www.w3.org/2000/svg">
              <!-- Layout grid -->
              <rect x="90" y="14" width="72" height="50" rx="8" stroke="currentColor" stroke-width="1.5" opacity="0.35"/>
              <rect x="94" y="18" width="30" height="42" rx="5" fill="var(--accent)" fill-opacity="0.12" stroke="var(--accent)" stroke-width="1.2"/>
              <rect x="128" y="18" width="30" height="20" rx="4" fill="var(--accent)" fill-opacity="0.08" stroke="var(--accent)" stroke-width="1.2"/>
              <rect x="128" y="40" width="30" height="20" rx="4" fill="var(--accent)" fill-opacity="0.08" stroke="var(--accent)" stroke-width="1.2"/>
              <!-- Keyboard -->
              <rect x="10" y="76" width="90" height="42" rx="10" stroke="currentColor" stroke-width="1.5" fill="var(--accent)" fill-opacity="0.05"/>
              <rect x="18" y="84" width="14" height="10" rx="3" stroke="currentColor" stroke-width="1" opacity="0.35"/>
              <rect x="36" y="84" width="14" height="10" rx="3" stroke="currentColor" stroke-width="1" opacity="0.35"/>
              <rect x="54" y="84" width="14" height="10" rx="3" stroke="currentColor" stroke-width="1" opacity="0.35"/>
              <rect x="72" y="84" width="20" height="10" rx="3" stroke="currentColor" stroke-width="1" opacity="0.35"/>
              <rect x="18" y="100" width="48" height="8" rx="3" stroke="currentColor" stroke-width="1" opacity="0.3"/>
              <!-- Arrow connecting -->
              <path d="M110 68v6" stroke="var(--accent)" stroke-width="1.5" stroke-linecap="round" opacity="0.5"/>
              <path d="M106 72l4 4 4-4" stroke="var(--accent)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" opacity="0.5"/>
            </svg>
          </div>
        </div>
      </div>

      <!-- ── Row 4: Displays & Spaces + Adaptive Tiling + App Blacklist ── -->

      <div class="glass-card p-6 hover:border-accent/30 transition-all duration-300 flex flex-col">
        <div class="w-11 h-11 rounded-xl flex items-center justify-center mb-4" style="background:linear-gradient(135deg, rgba(166,179,204,0.1), rgba(139,159,204,0.1));">
          <span class="text-accent">
            <svg class="w-6 h-6" viewBox="0 0 24 24" fill="none" stroke="var(--accent)" stroke-width="1.5">
              <rect x="1" y="5" width="9" height="7" rx="1.5"/><rect x="14" y="5" width="9" height="7" rx="1.5"/>
              <path d="M10 8.5h4" stroke-linecap="round"/>
              <path d="M5.5 14v2M18.5 14v2M4 16h3M17 16h3" stroke-linecap="round"/>
            </svg>
          </span>
        </div>
        <h3 class="text-lg font-semibold mb-2">Displays & Spaces</h3>
        <p class="text-text-secondary text-sm leading-relaxed">Move the focused window to another monitor or virtual desktop.</p>
      </div>

      <div class="glass-card p-6 hover:border-accent/30 transition-all duration-300 flex flex-col">
        <div class="w-11 h-11 rounded-xl flex items-center justify-center mb-4" style="background:linear-gradient(135deg, rgba(166,179,204,0.1), rgba(139,159,204,0.1));">
          <span class="text-accent">
            <svg class="w-6 h-6" viewBox="0 0 24 24" fill="none" stroke="var(--accent)" stroke-width="1.5">
              <rect x="2" y="2" width="9" height="9" rx="2"/><rect x="13" y="2" width="9" height="9" rx="2"/>
              <rect x="2" y="13" width="9" height="9" rx="2"/><rect x="13" y="13" width="9" height="9" rx="2"/>
              <path d="M11 6.5h2M11 17.5h2" stroke-linecap="round" stroke-dasharray="1.5 1.5"/>
            </svg>
          </span>
        </div>
        <h3 class="text-lg font-semibold mb-2">Adaptive Tiling</h3>
        <p class="text-text-secondary text-sm leading-relaxed">Tiles expand to fill remaining space around anchored neighbors.</p>
      </div>

      <div class="glass-card p-6 hover:border-accent/30 transition-all duration-300 flex flex-col">
        <div class="w-11 h-11 rounded-xl flex items-center justify-center mb-4" style="background:linear-gradient(135deg, rgba(166,179,204,0.1), rgba(139,159,204,0.1));">
          <span class="text-accent">
            <svg class="w-6 h-6" viewBox="0 0 24 24" fill="none" stroke="var(--accent)" stroke-width="1.5">
              <rect x="4" y="3" width="16" height="18" rx="3"/>
              <path d="M9 8h6M9 12h6M9 16h4" stroke-linecap="round"/>
              <circle cx="18" cy="18" r="5" fill="var(--bg, #1a1a2e)" stroke="var(--accent)" stroke-width="1.5"/>
              <path d="M16 16l4 4M20 16l-4 4" stroke-linecap="round" stroke-width="1.5"/>
            </svg>
          </span>
        </div>
        <h3 class="text-lg font-semibold mb-2">App Blacklist</h3>
        <p class="text-text-secondary text-sm leading-relaxed">Exclude apps you don't want ClickFit to control.</p>
      </div>

    </div>
  </div>
</section>
