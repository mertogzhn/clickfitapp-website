---
const features = [
  {
    icon: `<svg class="w-6 h-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M15 3h6v6M9 21H3v-6M21 3l-7 7M3 21l7-7"/></svg>`,
    title: 'Mouse Move & Resize',
    description: 'Hold a modifier key and left-click drag to move any window. Right-click drag to resize from any position. No need to grab tiny title bars or edges.',
  },
  {
    icon: `<svg class="w-6 h-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="2" y="3" width="8" height="8" rx="1"/><rect x="14" y="3" width="8" height="8" rx="1"/><rect x="2" y="13" width="8" height="8" rx="1"/><rect x="14" y="13" width="8" height="8" rx="1"/></svg>`,
    title: 'Edge Snapping & Tiling',
    description: 'Drag windows to screen edges to snap into tiled positions. 9 tile zones — halves, quarters, and full screen — with adaptive tiling that adjusts to neighboring windows.',
  },
  {
    icon: `<svg class="w-6 h-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="1" y="5" width="14" height="10" rx="1.5"/><rect x="9" y="9" width="14" height="10" rx="1.5"/><path d="M15 14h3" stroke-linecap="round"/></svg>`,
    title: 'Smart Snap',
    description: 'Windows automatically snap to each other\u2019s edges as you move them. Grab a shared border and both windows resize together in sync.',
  },
  {
    icon: `<svg class="w-6 h-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="2" y="4" width="20" height="16" rx="2"/><path d="M6 12h2M10 12h2M14 12h2M8 8h2M12 8h2M16 8h2M7 16h10"/></svg>`,
    title: 'Keyboard Shortcuts',
    description: 'Customizable global hotkeys for tiling, centering, maximizing, layouts, and cross-display moves. Record any key combination directly in the app.',
  },
  {
    icon: `<svg class="w-6 h-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="2" y="3" width="20" height="18" rx="2"/><path d="M12 3v18"/><path d="M2 9h8M14 9h8"/><path d="M2 15h8M14 15h8"/></svg>`,
    title: 'Predefined Layouts',
    description: 'Instantly arrange windows into 9 layout presets: columns, rows, grids, and split ratios. One shortcut to organize your entire workspace.',
  },
  {
    icon: `<svg class="w-6 h-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="1" y="5" width="10" height="7" rx="1.5"/><rect x="13" y="5" width="10" height="7" rx="1.5"/><path d="M6 16v2M18 16v2M4 18h4M16 18h4"/></svg>`,
    title: 'Multi-Monitor & Spaces',
    description: 'Move windows between displays and virtual desktops with a keystroke. Works seamlessly across any multi-monitor setup.',
  },
  {
    icon: `<svg class="w-6 h-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="5" y="2" width="14" height="20" rx="3"/><circle cx="12" cy="18" r="1"/><path d="M9 2v1h6V2"/></svg>`,
    title: 'Menu Bar App',
    description: 'Lives in your menu bar with zero visual overhead. Quick access to settings, action hub, and layout controls from one compact popover.',
  },
  {
    icon: `<svg class="w-6 h-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M13 2L3 14h9l-1 8 10-12h-9l1-8z"/></svg>`,
    title: 'Lightweight & Fast',
    description: 'Native Swift app with vsync-aligned updates. Minimal memory footprint and optimized for Chrome and Electron apps. Runs quietly without slowing your Mac.',
  },
];
---

<section id="features" class="relative py-24 md:py-32">
  <div class="max-w-6xl mx-auto px-6">
    <!-- Section Header -->
    <div class="text-center mb-16">
      <p class="text-accent text-sm font-medium tracking-wide uppercase mb-3">Features</p>
      <h2 class="text-3xl md:text-4xl font-bold tracking-tight mb-4">
        Everything you need to manage windows
      </h2>
      <p class="text-text-secondary text-lg max-w-xl mx-auto">
        Powerful features packed into a lightweight, native macOS app.
      </p>
    </div>

    <!-- Feature Grid -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-5">
      {features.map((feature) => (
        <div class="group relative p-6 glass-card hover:bg-bg-secondary/80 transition-all duration-300">
          <div class="w-12 h-12 rounded-xl bg-accent/10 text-accent flex items-center justify-center mb-4 group-hover:bg-accent/20 transition-colors">
            <Fragment set:html={feature.icon} />
          </div>
          <h3 class="text-lg font-semibold mb-2">{feature.title}</h3>
          <p class="text-text-secondary text-sm leading-relaxed">{feature.description}</p>
        </div>
      ))}
    </div>
  </div>
</section>
