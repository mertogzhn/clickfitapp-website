  :global(:root:not(.dark)) .browser-url-bar { background: rgba(0,0,0,0.03); border-bottom-color: rgba(0,0,0,0.06); }
  :global(:root:not(.dark)) .browser-nav-btn { background: rgba(0,0,0,0.1); }
  :global(:root:not(.dark)) .browser-url-field { background: rgba(0,0,0,0.04); }
  :global(:root:not(.dark)) .browser-url-text { background: rgba(0,0,0,0.1); }
  :global(:root:not(.dark)) .browser-hero-img { background: linear-gradient(135deg, rgba(0,0,0,0.06) 0%, rgba(0,0,0,0.03) 100%); }
