  /* Editor body in Slide 4 anchor uses darker bg */
  .s4-anchor .sc-win-body { background: #12161F; }
  :global(:root:not(.dark)) .s4-anchor .sc-win-body { background: #F0F0F5; }
  .s0-terminal .sc-win-body { background: #0F1319; }
