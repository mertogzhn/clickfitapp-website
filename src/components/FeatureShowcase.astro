  :global(:root:not(.dark)) .s0-resize-cursor svg path,
  :global(:root:not(.dark)) .s1-resize-cursor svg path,
  :global(:root:not(.dark)) .s5-resize-cursor svg path { stroke: black; }

  :global(:root:not(.dark)) .s0-browser,
  :global(:root:not(.dark)) .s0-editor,
  :global(:root:not(.dark)) .s0-terminal,
  :global(:root:not(.dark)) .s1-win,
  :global(:root:not(.dark)) .s2-win,
  :global(:root:not(.dark)) .s3-preview,
  :global(:root:not(.dark)) .s4-anchor,
