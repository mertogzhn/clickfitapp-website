<script is:inline>
(function() {
  var showcase = document.querySelector('.feature-showcase');
  if (!showcase) return;

  var viewport = showcase.querySelector('.showcase-viewport');
  var slides = showcase.querySelectorAll('.showcase-slide');
  var thumbs = showcase.querySelectorAll('.showcase-thumb');
  var currentSlide = 0;
  var autoTimer = null;
  var resumeTimer = null;
  var isPaused = false;
  var isInView = true;
  var reducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

  // Duration per slide in ms (read from data attribute)
  function getDuration(index) {
    var slide = slides[index];
    return slide ? parseInt(slide.getAttribute('data-duration'), 10) || 8000 : 8000;
  }

  function activateSlide(index) {
    index = ((index % slides.length) + slides.length) % slides.length;

    // Deactivate all
    for (var i = 0; i < slides.length; i++) {
      slides[i].classList.remove('active');
      thumbs[i].classList.remove('active');
      thumbs[i].setAttribute('aria-selected', 'false');
    }

    // Activate new slide
    slides[index].classList.add('active');
    thumbs[index].classList.add('active');
    thumbs[index].setAttribute('aria-selected', 'true');

    // Set progress bar duration as CSS variable
    var dur = getDuration(index);
    thumbs[index].style.setProperty('--slide-duration', dur + 'ms');

    currentSlide = index;

    // Schedule auto-advance
    clearTimeout(autoTimer);
    if (!isPaused && isInView && !reducedMotion) {
      autoTimer = setTimeout(function() {
        activateSlide(currentSlide + 1);
      }, dur);
    }
  }

  // Click handlers on thumbnails
  for (var i = 0; i < thumbs.length; i++) {
    (function(idx) {
      thumbs[idx].addEventListener('click', function() {
        activateSlide(idx);
        pauseAutoAdvance();
      });
    })(i);
  }

  // Keyboard navigation
  showcase.addEventListener('keydown', function(e) {
    if (e.key === 'ArrowRight' || e.key === 'ArrowDown') {
      e.preventDefault();
      activateSlide(currentSlide + 1);
      pauseAutoAdvance();
    } else if (e.key === 'ArrowLeft' || e.key === 'ArrowUp') {
      e.preventDefault();
      activateSlide(currentSlide - 1);
      pauseAutoAdvance();
    }
  });

  function pauseAutoAdvance() {
    isPaused = true;
    clearTimeout(autoTimer);
    clearTimeout(resumeTimer);
    // Resume after 30s of no interaction
    resumeTimer = setTimeout(function() {
      isPaused = false;
      if (isInView && !reducedMotion) {
        var remaining = getDuration(currentSlide);
        autoTimer = setTimeout(function() {
          activateSlide(currentSlide + 1);
        }, remaining);
      }
    }, 30000);
  }

  // IntersectionObserver: pause/resume when in/out of viewport
  if ('IntersectionObserver' in window) {
    var observer = new IntersectionObserver(function(entries) {
      entries.forEach(function(entry) {
        isInView = entry.isIntersecting;
        if (!isInView) {
          clearTimeout(autoTimer);
          // Pause all CSS animations
          viewport.querySelectorAll('[class*="s0-"],[class*="s1-"],[class*="s2-"],[class*="s3-"],[class*="s4-"],[class*="s5-"]').forEach(function(el) {
            el.style.animationPlayState = 'paused';
          });
        } else {
          // Resume CSS animations
          viewport.querySelectorAll('[class*="s0-"],[class*="s1-"],[class*="s2-"],[class*="s3-"],[class*="s4-"],[class*="s5-"]').forEach(function(el) {
            el.style.animationPlayState = '';
          });
          // Restart auto-advance if not user-paused
          if (!isPaused && !reducedMotion) {
            clearTimeout(autoTimer);
            autoTimer = setTimeout(function() {
              activateSlide(currentSlide + 1);
            }, getDuration(currentSlide));
          }
        }
      });
    }, { threshold: 0.2 });
    observer.observe(viewport);
  }

  // Reduced motion: show slide 0 static, no auto-advance
  if (reducedMotion) {
    activateSlide(0);
    return;
  }

  // Initial activation
  activateSlide(0);
})();
