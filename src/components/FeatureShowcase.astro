  :global(:root:not(.dark)) .s0-editor .sc-win-body { background: #F0F0F5; }

  /* ══════════════════════════════════════════════════════════
     THUMBNAIL STRIP
     ══════════════════════════════════════════════════════════ */
  .showcase-thumb {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 4px;
    padding: 8px 10px 6px;
    border-radius: 10px;
    border: 1px solid transparent;
    background: transparent;
    cursor: pointer;
    position: relative;
    transition: border-color 0.2s ease, background-color 0.2s ease;
    min-width: 0;
    flex: 1;
    max-width: 140px;
  }
  .showcase-thumb:hover {
    background: var(--surface-glass);
    border-color: var(--border);
  }
  .showcase-thumb.active {
    background: var(--surface-glass);
    border-color: var(--accent);
  }

  .thumb-icon {
    width: 40px;
    height: 26px;
    color: var(--text-secondary);
    transition: color 0.2s ease;
  }
  .showcase-thumb.active .thumb-icon {
    color: var(--accent);
  }

  .thumb-label {
    font-size: 10px;
    font-weight: 500;
    color: var(--text-secondary);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    max-width: 100%;
    transition: color 0.2s ease;
  }
  .showcase-thumb.active .thumb-label {
    color: var(--text-primary);
  }

  .thumb-progress {
    width: 100%;
    height: 2px;
    background: var(--border);
    border-radius: 1px;
    overflow: hidden;
  }
  .thumb-progress-bar {
    height: 100%;
    width: 0%;
    background: var(--accent);
    border-radius: 1px;
  }
  .showcase-thumb.active .thumb-progress-bar {
    animation: thumb-fill var(--slide-duration, 15s) linear forwards;
  }
  @keyframes thumb-fill {
    from { width: 0%; }
    to { width: 100%; }
  }

  /* ══════════════════════════════════════════════════════════
     PERFORMANCE HINTS (only for active slide)
     ══════════════════════════════════════════════════════════ */
  .showcase-slide.active .s0-browser,
  .showcase-slide.active .s0-editor,
  .showcase-slide.active .s0-terminal {
    will-change: top, left, width, height, border-radius;
  }
  .showcase-slide.active .s0-cursor,
  .showcase-slide.active .s0-resize-cursor,
  .showcase-slide.active .s1-cursor,
  .showcase-slide.active .s1-resize-cursor {
    will-change: transform, opacity;
  }
  .showcase-slide.active .s0-badge,
  .showcase-slide.active .s1-badge,
  .showcase-slide.active .s2-badge,
  .showcase-slide.active .s4-badge,
  .showcase-slide.active .s5-badge {
    will-change: opacity, transform;
  }
  .showcase-slide.active .s4-cursor {
    will-change: top, left, opacity;
  }
  .showcase-slide.active .s5-resize-cursor {
    will-change: top, left, opacity;
  }
  .showcase-slide.active .s0-tile-tl,
  .showcase-slide.active .s0-tile-bl,
  .showcase-slide.active .s0-tile-rh,
  .showcase-slide.active .s2-zone,
  .showcase-slide.active .s4-zone {
    will-change: opacity;
  }
  .showcase-slide.active .s1-win {
    will-change: top, left, width, height;
  }
  .showcase-slide.active .s2-win {
    will-change: top, left, width, height, border-radius;
  }
  .showcase-slide.active .s3-layout,
  .showcase-slide.active .s3-badge {
    will-change: opacity, transform;
  }
  .showcase-slide.active .s4-floating {
    will-change: top, left, width, height, border-radius;
  }
  .showcase-slide.active .s5-left,
  .showcase-slide.active .s5-right-stack {
    will-change: width, left;
  }

  /* ══════════════════════════════════════════════════════════
     SLIDE 0 — HERO ANIMATION (15s)
     ══════════════════════════════════════════════════════════ */
  .showcase-slide.active[data-slide="0"] {
    --dur: 15s;
  }

  .s0-badge {
    position: absolute;
    top: 0;
    left: 0;
    opacity: 0;
    transform: translateX(-50%) scale(0.85);
    transform-origin: center center;
  }
  .showcase-slide.active[data-slide="0"] .s0-badge-1 { animation: s0-b1 var(--dur) ease infinite; }
  .showcase-slide.active[data-slide="0"] .s0-badge-2 { animation: s0-b2 var(--dur) ease infinite; }
  .showcase-slide.active[data-slide="0"] .s0-badge-3 { animation: s0-b3 var(--dur) ease infinite; }
  .showcase-slide.active[data-slide="0"] .s0-badge-4 { animation: s0-b4 var(--dur) ease infinite; }
  @keyframes s0-b1 { 0%{opacity:0;transform:translateX(-50%) scale(0.85);} 12%{opacity:0;transform:translateX(-50%) scale(0.85);} 15%{opacity:1;transform:translateX(-50%) scale(1);} 21%{opacity:1;transform:translateX(-50%) scale(1);} 24%{opacity:0;transform:translateX(-50%) scale(0.85);} 100%{opacity:0;transform:translateX(-50%) scale(0.85);} }
  @keyframes s0-b2 { 0%{opacity:0;transform:translateX(-50%) scale(0.85);} 27%{opacity:0;transform:translateX(-50%) scale(0.85);} 30%{opacity:1;transform:translateX(-50%) scale(1);} 36%{opacity:1;transform:translateX(-50%) scale(1);} 39%{opacity:0;transform:translateX(-50%) scale(0.85);} 100%{opacity:0;transform:translateX(-50%) scale(0.85);} }
  @keyframes s0-b3 { 0%{opacity:0;transform:translateX(-50%) scale(0.85);} 42%{opacity:0;transform:translateX(-50%) scale(0.85);} 45%{opacity:1;transform:translateX(-50%) scale(1);} 51%{opacity:1;transform:translateX(-50%) scale(1);} 54%{opacity:0;transform:translateX(-50%) scale(0.85);} 100%{opacity:0;transform:translateX(-50%) scale(0.85);} }
  @keyframes s0-b4 { 0%{opacity:0;transform:translateX(-50%) scale(0.85);} 55%{opacity:0;transform:translateX(-50%) scale(0.85);} 58%{opacity:1;transform:translateX(-50%) scale(1);} 77%{opacity:1;transform:translateX(-50%) scale(1);} 80%{opacity:0;transform:translateX(-50%) scale(0.85);} 100%{opacity:0;transform:translateX(-50%) scale(0.85);} }

  .showcase-slide.active[data-slide="0"] .s0-cursor {
    animation: s0-cursor var(--dur) cubic-bezier(0.4,0,0.2,1) infinite;
    top: 50%; left: 50%;
  }
  @keyframes s0-cursor {
    0%    { transform: translate(0, 0); opacity: 1; }
    5%    { transform: translate(0, 0); opacity: 1; }
    10%   { transform: translate(-99px, -118px); opacity: 1; }
    19%   { transform: translate(-269px, -157px); opacity: 1; }
    20%   { transform: translate(-224px, -140px); opacity: 1; }
    21%   { transform: translate(-224px, -140px); opacity: 1; }
    25%   { transform: translate(-242px, 123px); opacity: 1; }
    34%   { transform: translate(-287px, 155px); opacity: 1; }
    35%   { transform: translate(-224px, 140px); opacity: 1; }
    36%   { transform: translate(-224px, 140px); opacity: 1; }
    40%   { transform: translate(134px, -17px); opacity: 1; }
    49%   { transform: translate(197px, -25px); opacity: 1; }
    50%   { transform: translate(224px, 0px); opacity: 1; }
    51%   { transform: translate(224px, 0px); opacity: 1; }
    55%   { transform: translate(0, 0); opacity: 1; }
    56%   { transform: translate(0, 0); opacity: 0; }
    78%   { transform: translate(0, 0); opacity: 0; }
    79%   { transform: translate(0, 0); opacity: 1; }
    87%   { transform: translate(0, 0); opacity: 1; }
    100%  { transform: translate(0, 0); opacity: 1; }
  }

  .showcase-slide.active[data-slide="0"] .s0-browser {
    animation: s0-browser var(--dur) cubic-bezier(0.4,0,0.2,1) infinite;
  }
  @keyframes s0-browser {
    0%    { top: 8%; left: 20%; width: 38%; height: 42%; border-radius: 10px; }
    10%   { top: 8%; left: 20%; width: 38%; height: 42%; border-radius: 10px; }
    19%   { top: 1%; left: 1%; width: 38%; height: 42%; border-radius: 6px; }
    20%   { top: 0%; left: 0%; width: 50%; height: 50%; border-radius: 0; }
    57%   { top: 0%; left: 0%; width: 50%; height: 50%; border-radius: 0; }
    68%   { top: 0%; left: 0%; width: 58%; height: 50%; border-radius: 0; }
    78%   { top: 0%; left: 0%; width: 58%; height: 50%; border-radius: 0; }
    87%   { top: 8%; left: 20%; width: 38%; height: 42%; border-radius: 10px; }
    100%  { top: 8%; left: 20%; width: 38%; height: 42%; border-radius: 10px; }
  }

  .showcase-slide.active[data-slide="0"] .s0-editor {
    animation: s0-editor var(--dur) cubic-bezier(0.4,0,0.2,1) infinite;
  }
  @keyframes s0-editor {
    0%    { top: 12%; left: 42%; width: 46%; height: 70%; border-radius: 10px; }
    40%   { top: 12%; left: 42%; width: 46%; height: 70%; border-radius: 10px; }
    49%   { top: 10%; left: 49%; width: 46%; height: 70%; border-radius: 6px; }
    50%   { top: 0%; left: 50%; width: 50%; height: 100%; border-radius: 0; }
    57%   { top: 0%; left: 50%; width: 50%; height: 100%; border-radius: 0; }
    68%   { top: 0%; left: 58%; width: 42%; height: 100%; border-radius: 0; }
    78%   { top: 0%; left: 58%; width: 42%; height: 100%; border-radius: 0; }
    87%   { top: 12%; left: 42%; width: 46%; height: 70%; border-radius: 10px; }
    100%  { top: 12%; left: 42%; width: 46%; height: 70%; border-radius: 10px; }
  }

  .showcase-slide.active[data-slide="0"] .s0-terminal {
    animation: s0-terminal var(--dur) cubic-bezier(0.4,0,0.2,1) infinite;
  }
  @keyframes s0-terminal {
    0%    { top: 54%; left: 6%; width: 34%; height: 36%; border-radius: 10px; }
    25%   { top: 54%; left: 6%; width: 34%; height: 36%; border-radius: 10px; }
    34%   { top: 58%; left: 1%; width: 34%; height: 36%; border-radius: 6px; }
    35%   { top: 50%; left: 0%; width: 50%; height: 50%; border-radius: 0; }
    57%   { top: 50%; left: 0%; width: 50%; height: 50%; border-radius: 0; }
    68%   { top: 50%; left: 0%; width: 58%; height: 50%; border-radius: 0; }
    78%   { top: 50%; left: 0%; width: 58%; height: 50%; border-radius: 0; }
    87%   { top: 54%; left: 6%; width: 34%; height: 36%; border-radius: 10px; }
    100%  { top: 54%; left: 6%; width: 34%; height: 36%; border-radius: 10px; }
  }

  .showcase-slide.active[data-slide="0"] .s0-tile-tl { animation: s0-tile-tl var(--dur) ease infinite; }
  @keyframes s0-tile-tl {
    0% { opacity:0; } 15% { opacity:0; } 17% { opacity:1; } 19% { opacity:1; } 21% { opacity:0; } 100% { opacity:0; }
  }
  .showcase-slide.active[data-slide="0"] .s0-tile-bl { animation: s0-tile-bl var(--dur) ease infinite; }
  @keyframes s0-tile-bl {
    0% { opacity:0; } 30% { opacity:0; } 32% { opacity:1; } 34% { opacity:1; } 36% { opacity:0; } 100% { opacity:0; }
  }
  .showcase-slide.active[data-slide="0"] .s0-tile-rh { animation: s0-tile-rh var(--dur) ease infinite; }
  @keyframes s0-tile-rh {
    0% { opacity:0; } 45% { opacity:0; } 47% { opacity:1; } 49% { opacity:1; } 51% { opacity:0; } 100% { opacity:0; }
  }

  .showcase-slide.active[data-slide="0"] .s0-resize-cursor {
    animation: s0-resize var(--dur) cubic-bezier(0.4,0,0.2,1) infinite;
    top: 50%; left: 50%;
  }
  @keyframes s0-resize {
    0%  { transform: translate(0,0); opacity:0; }
    55% { transform: translate(0,0); opacity:0; }
    56% { transform: translate(0,0); opacity:1; }
    57% { transform: translate(0,0); opacity:1; }
    68% { transform: translate(72px,0); opacity:1; }
    75% { transform: translate(72px,0); opacity:1; }
    77% { transform: translate(72px,0); opacity:0; }
    100%{ transform: translate(0,0); opacity:0; }
  }

  /* ══════════════════════════════════════════════════════════
     SLIDE 1 — MOVE & RESIZE (10s forwards)
     Choreography:
       0-10%:  cursor appears, moves to window center (top-right)
       10-32%: drag window to bottom-center
       36-55%: drag window to top-left
       58-68%: cursor glides once to the lower-right grab area
       70-88%: resize drag (cursor delta === window delta)
       88-100%: hold final state
     ══════════════════════════════════════════════════════════ */

  /* ── Move badge: visible during move phase ── */
  .s1-badge {
    position: absolute;
    top: 0;
    left: 0;
    opacity: 0;
    transform: translateX(-50%) scale(0.85);
    transform-origin: center center;
  }
  .showcase-slide.active[data-slide="1"] .s1-badge-move {
    animation: s1-badge-move 10s ease forwards;
  }
  @keyframes s1-badge-move {
    0%   { opacity: 0; transform: translateX(-50%) scale(0.85); }
    4%   { opacity: 1; transform: translateX(-50%) scale(1); }
    55%  { opacity: 1; transform: translateX(-50%) scale(1); }
    60%  { opacity: 0; transform: translateX(-50%) scale(0.85); }
    100% { opacity: 0; transform: translateX(-50%) scale(0.85); }
  }

  /* ── Resize badge: visible during resize phase ── */
  .showcase-slide.active[data-slide="1"] .s1-badge-resize {
    animation: s1-badge-resize 10s ease forwards;
  }
  @keyframes s1-badge-resize {
    0%   { opacity: 0; transform: translateX(-50%) scale(0.85); }
    60%  { opacity: 0; transform: translateX(-50%) scale(0.85); }
    65%  { opacity: 1; transform: translateX(-50%) scale(1); }
    100% { opacity: 1; transform: translateX(-50%) scale(1); }
  }

  /* ── Window: single window, move then resize ── */
  .showcase-slide.active[data-slide="1"] .s1-win {
    animation: s1-win 10s cubic-bezier(0.4,0,0.2,1) forwards;
  }
  @keyframes s1-win {
    /* Start: top-right area */
    0%   { top: 5%;  left: 46%; width: 38%; height: 42%; border-radius: 10px; }
    10%  { top: 5%;  left: 46%; width: 38%; height: 42%; border-radius: 10px; }
    /* Move 1: to bottom-center */
    32%  { top: 42%; left: 28%; width: 38%; height: 42%; border-radius: 10px; }
    36%  { top: 42%; left: 28%; width: 38%; height: 42%; border-radius: 10px; }
    /* Move 2: to top-left */
    55%  { top: 8%;  left: 14%; width: 38%; height: 42%; border-radius: 10px; }
    70%  { top: 8%;  left: 14%; width: 38%; height: 42%; border-radius: 10px; }
    /* Resize: grow right edge + bottom edge (left edge & top stay fixed) */
    88%  { top: 8%;  left: 14%; width: 54%; height: 60%; border-radius: 10px; }
    100% { top: 8%;  left: 14%; width: 54%; height: 60%; border-radius: 10px; }
  }

  /* ── Cursor: tracks window center during moves, then goes to resize corner ── */
  .showcase-slide.active[data-slide="1"] .s1-cursor {
    animation: s1-cursor 10s cubic-bezier(0.4,0,0.2,1) forwards;
    top: 50%; left: 50%;
  }
  @keyframes s1-cursor {
    0%   { transform: translate(0, 0); opacity: 0; }
    4%   { transform: translate(0, 0); opacity: 1; }
    /* Arrive at window center (top-right: 65%,26%) */
    10%  { transform: translate(135px, -140px); opacity: 1; }
    /* Drag to bottom-center (window center: 47%,63%) */
    32%  { transform: translate(-27px, 67px); opacity: 1; }
    36%  { transform: translate(-27px, 67px); opacity: 1; }
    /* Drag to top-left (window center: 33%,29%) */
    55%  { transform: translate(-153px, -123px); opacity: 1; }
    58%  { transform: translate(-153px, -123px); opacity: 1; }
    /* Glide once to the lower-right interior grab point */
    68%  { transform: translate(-30px, -36px); opacity: 1; }
    /* Hide — handoff to resize cursor */
    70%  { transform: translate(-30px, -36px); opacity: 0; }
    100% { transform: translate(-30px, -36px); opacity: 0; }
  }

  /* ── Resize cursor: appears at the lower-right grab area, drags outward ── */
  .showcase-slide.active[data-slide="1"] .s1-resize-cursor {
    animation: s1-resize-cursor 10s cubic-bezier(0.4,0,0.2,1) forwards;
    top: 50%; left: 50%;
  }
  @keyframes s1-resize-cursor {
    0%   { transform: translate(-30px, -36px); opacity: 0; }
    69%  { transform: translate(-30px, -36px); opacity: 0; }
    /* Appear at the lower-right grab area */
