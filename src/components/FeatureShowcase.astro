---
---

<!-- Interactive Feature Showcase Slider -->
<div class="feature-showcase relative mx-auto max-w-4xl mt-16" data-animate="scale-in">
  <!-- Outer glow -->
  <div class="absolute inset-0 bg-accent/5 rounded-2xl blur-2xl pointer-events-none"></div>

  <!-- ═══ VIEWPORT ═══ -->
  <div class="showcase-viewport relative rounded-2xl overflow-hidden border border-black/[0.08] dark:border-white/[0.06]" style="aspect-ratio:16/10; contain:layout style paint;">

    <!-- ────────────────────────────────────────────────── -->
    <!-- SLIDE 0 — Hero Animation (15s)                    -->
    <!-- ────────────────────────────────────────────────── -->
    <div class="showcase-slide active" data-slide="0" data-duration="15000">
      <!-- Window: Browser -->
      <div class="s0-win s0-browser absolute rounded-[10px] overflow-hidden" style="top:8%;left:20%;width:38%;height:42%; box-shadow:0 8px 32px rgba(0,0,0,0.4); border:1px solid rgba(255,255,255,0.08); z-index:2;">
        <div class="sc-titlebar flex items-center h-7 px-3 gap-1.5">
          <span class="w-2.5 h-2.5 rounded-full" style="background:#FF5F57;"></span>
          <span class="w-2.5 h-2.5 rounded-full" style="background:#FEBC2E;"></span>
          <span class="w-2.5 h-2.5 rounded-full" style="background:#28C840;"></span>
        </div>
        <div class="sc-win-body browser-body">
          <div class="browser-url-bar">
            <div class="browser-nav-btns"><span class="browser-nav-btn"></span><span class="browser-nav-btn"></span></div>
            <div class="browser-url-field"><span class="browser-lock">&#x1F512;</span><span class="browser-url-text"></span></div>
          </div>
          <div class="browser-page">
            <div class="browser-hero-img"></div>
            <div class="browser-heading"></div>
            <div class="browser-text w-full"></div>
            <div class="browser-text w-[85%]"></div>
            <div class="browser-text w-[70%]"></div>
            <div class="browser-cards">
              <div class="browser-card"><div class="browser-card-img"></div><div class="browser-text w-[90%]"></div><div class="browser-text w-[60%]"></div></div>
              <div class="browser-card"><div class="browser-card-img"></div><div class="browser-text w-[80%]"></div><div class="browser-text w-[50%]"></div></div>
            </div>
          </div>
        </div>
      </div>

      <!-- Window: Code Editor -->
      <div class="s0-win s0-editor absolute rounded-[10px] overflow-hidden" style="top:12%;left:42%;width:46%;height:70%; box-shadow:0 8px 32px rgba(0,0,0,0.4); border:1px solid rgba(255,255,255,0.08); z-index:3;">
        <div class="sc-titlebar flex items-center h-7 px-3 gap-1.5">
          <span class="w-2.5 h-2.5 rounded-full" style="background:#FF5F57;"></span>
          <span class="w-2.5 h-2.5 rounded-full" style="background:#FEBC2E;"></span>
          <span class="w-2.5 h-2.5 rounded-full" style="background:#28C840;"></span>
        </div>
        <div class="sc-win-body editor-body">
          <div class="editor-sidebar">
            <div class="editor-section-head"></div>
            <div class="editor-file active"></div>
            <div class="editor-file"></div>
            <div class="editor-file indent"></div>
            <div class="editor-file indent"></div>
            <div class="editor-file indent"></div>
            <div class="editor-file"></div>
            <div class="editor-file indent"></div>
            <div class="editor-file indent"></div>
          </div>
          <div class="editor-code">
            <div class="code-line"><span class="ln-gutter"></span><span class="code-block kw-block" style="width:18%"></span> <span class="code-block str-block" style="width:28%"></span></div>
            <div class="code-line"><span class="ln-gutter"></span></div>
            <div class="code-line"><span class="ln-gutter"></span><span class="code-block kw-block" style="width:14%"></span> <span class="code-block type-block" style="width:32%"></span> <span class="code-block br-block" style="width:4%"></span></div>
            <div class="code-line"><span class="ln-gutter"></span><span class="code-indent"></span><span class="code-block kw-block" style="width:12%"></span> <span class="code-block var-block" style="width:22%"></span><span class="code-block p-block" style="width:3%"></span> <span class="code-block type-block" style="width:20%"></span></div>
            <div class="code-line"><span class="ln-gutter"></span><span class="code-indent"></span><span class="code-block kw-block" style="width:12%"></span> <span class="code-block var-block" style="width:16%"></span><span class="code-block p-block" style="width:3%"></span> <span class="code-block type-block" style="width:18%"></span></div>
            <div class="code-line"><span class="ln-gutter"></span></div>
            <div class="code-line"><span class="ln-gutter"></span><span class="code-indent"></span><span class="code-block kw-block" style="width:14%"></span> <span class="code-block fn-block" style="width:18%"></span><span class="code-block p-block" style="width:6%"></span> <span class="code-block br-block" style="width:4%"></span></div>
            <div class="code-line"><span class="ln-gutter"></span><span class="code-indent"></span><span class="code-indent"></span><span class="code-block var-block" style="width:22%"></span> <span class="code-block p-block" style="width:4%"></span> <span class="code-block var-block" style="width:16%"></span></div>
            <div class="code-line"><span class="ln-gutter"></span><span class="code-indent"></span><span class="code-indent"></span><span class="code-block fn-block" style="width:26%"></span><span class="code-block p-block" style="width:6%"></span></div>
            <div class="code-line"><span class="ln-gutter"></span><span class="code-indent"></span><span class="code-block br-block" style="width:4%"></span></div>
            <div class="code-line"><span class="ln-gutter"></span></div>
            <div class="code-line"><span class="ln-gutter"></span><span class="code-indent"></span><span class="code-block kw-block" style="width:14%"></span> <span class="code-block fn-block" style="width:20%"></span><span class="code-block p-block" style="width:8%"></span> <span class="code-block br-block" style="width:4%"></span></div>
            <div class="code-line"><span class="ln-gutter"></span><span class="code-indent"></span><span class="code-indent"></span><span class="code-block kw-block" style="width:12%"></span> <span class="code-block var-block" style="width:18%"></span> <span class="code-block p-block" style="width:4%"></span> <span class="code-block fn-block" style="width:22%"></span></div>
            <div class="code-line"><span class="ln-gutter"></span><span class="code-indent"></span><span class="code-indent"></span><span class="code-block var-block" style="width:16%"></span> <span class="code-block p-block" style="width:4%"></span> <span class="code-block var-block" style="width:14%"></span></div>
            <div class="code-line"><span class="ln-gutter"></span><span class="code-indent"></span><span class="code-block br-block" style="width:4%"></span></div>
            <div class="code-line"><span class="ln-gutter"></span><span class="code-block br-block" style="width:4%"></span></div>
          </div>
        </div>
      </div>

      <!-- Window: Terminal -->
      <div class="s0-win s0-terminal absolute rounded-[10px] overflow-hidden" style="top:54%;left:6%;width:34%;height:36%; box-shadow:0 8px 32px rgba(0,0,0,0.4); border:1px solid rgba(255,255,255,0.08); z-index:1;">
        <div class="sc-titlebar flex items-center h-7 px-3 gap-1.5">
          <span class="w-2.5 h-2.5 rounded-full" style="background:#FF5F57;"></span>
          <span class="w-2.5 h-2.5 rounded-full" style="background:#FEBC2E;"></span>
          <span class="w-2.5 h-2.5 rounded-full" style="background:#28C840;"></span>
        </div>
        <div class="sc-win-body terminal-body">
          <div class="term-line"><span class="term-prompt-block"></span> <span class="term-cmd-block" style="width:38%"></span></div>
          <div class="term-line"><span class="term-out-block" style="width:52%"></span></div>
          <div class="term-line"><span class="term-out-block" style="width:60%"></span></div>
          <div class="term-line"></div>
          <div class="term-line"><span class="term-prompt-block"></span> <span class="term-cmd-block" style="width:30%"></span></div>
          <div class="term-line"><span class="term-out-block term-green-block" style="width:55%"></span></div>
          <div class="term-line"><span class="term-out-block term-green-block" style="width:48%"></span></div>
          <div class="term-line"></div>
          <div class="term-line"><span class="term-prompt-block"></span> <span class="term-cursor-block"></span></div>
        </div>
      </div>

      <!-- Tile overlays -->
      <div class="s0-tile-tl absolute rounded-lg opacity-0 pointer-events-none" style="top:2%;left:2%;width:46%;height:46%; border:2px solid var(--accent); background:rgba(166,179,204,0.10); z-index:10;"></div>
      <div class="s0-tile-bl absolute rounded-lg opacity-0 pointer-events-none" style="top:52%;left:2%;width:46%;height:46%; border:2px solid var(--accent); background:rgba(166,179,204,0.10); z-index:10;"></div>
      <div class="s0-tile-rh absolute rounded-lg opacity-0 pointer-events-none" style="top:2%;left:52%;width:46%;height:96%; border:2px solid var(--accent); background:rgba(166,179,204,0.10); z-index:10;"></div>

      <!-- Overview badges -->
      <div class="s0-badge-wrap absolute pointer-events-none" style="top:4%;left:50%;width:0;z-index:20;">
        <div class="s0-badge s0-badge-1 sc-badge">
          <span class="sc-badge-keys" aria-hidden="true">
            <span class="sc-badge-key">⇧</span>
            <span class="sc-badge-key">⌘</span>
            <span class="sc-badge-key">←</span>
            <span class="sc-badge-key">↑</span>
          </span>
        </div>
        <div class="s0-badge s0-badge-2 sc-badge">
          <span class="sc-badge-keys" aria-hidden="true">
            <span class="sc-badge-key">⇧</span>
            <span class="sc-badge-key">⌘</span>
            <span class="sc-badge-key">←</span>
            <span class="sc-badge-key">↓</span>
          </span>
        </div>
        <div class="s0-badge s0-badge-3 sc-badge">
          <span class="sc-badge-keys" aria-hidden="true">
            <span class="sc-badge-key">⇧</span>
            <span class="sc-badge-key">⌘</span>
            <span class="sc-badge-key">→</span>
          </span>
        </div>
        <div class="s0-badge s0-badge-4 sc-badge">
          <span class="sc-badge-keys" aria-hidden="true">
            <span class="sc-badge-key">⇧</span>
            <span class="sc-badge-key">⌘</span>
          </span>
          <span class="sc-badge-copy">Right Click</span>
        </div>
      </div>

      <!-- Cursor -->
      <div class="s0-cursor absolute pointer-events-none" style="width:18px;height:24px;z-index:50;filter:drop-shadow(0 2px 4px rgba(0,0,0,0.5));">
        <svg viewBox="0 0 18 24" fill="none" xmlns="http://www.w3.org/2000/svg">
          <path d="M1 1L1 17.5L5.5 13.5L9 21L12 19.5L8.5 12.5L14 12L1 1Z" fill="white" stroke="black" stroke-width="0.5"/>
        </svg>
      </div>

      <!-- Resize cursor -->
      <div class="s0-resize-cursor absolute pointer-events-none opacity-0" style="width:20px;height:20px;z-index:50;filter:drop-shadow(0 2px 4px rgba(0,0,0,0.5));">
        <svg viewBox="0 0 20 20" fill="none" xmlns="http://www.w3.org/2000/svg">
          <path d="M1 10H19M1 10L5 6M1 10L5 14M19 10L15 6M19 10L15 14" stroke="white" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </div>
    </div>

    <!-- ────────────────────────────────────────────────── -->
    <!-- SLIDE 1 — Move & Resize (10s)                     -->
    <!-- ────────────────────────────────────────────────── -->
    <div class="showcase-slide" data-slide="1" data-duration="10000">
      <!-- Single window -->
      <div class="s1-win absolute rounded-[10px] overflow-hidden" style="top:5%;left:46%;width:38%;height:42%; box-shadow:0 8px 32px rgba(0,0,0,0.4); border:1px solid rgba(255,255,255,0.08); z-index:2;">
        <div class="sc-titlebar flex items-center h-7 px-3 gap-1.5">
          <span class="w-2.5 h-2.5 rounded-full" style="background:#FF5F57;"></span>
          <span class="w-2.5 h-2.5 rounded-full" style="background:#FEBC2E;"></span>
          <span class="w-2.5 h-2.5 rounded-full" style="background:#28C840;"></span>
        </div>
        <div class="sc-win-body browser-body">
          <div class="browser-url-bar">
            <div class="browser-nav-btns"><span class="browser-nav-btn"></span><span class="browser-nav-btn"></span></div>
            <div class="browser-url-field"><span class="browser-lock">&#x1F512;</span><span class="browser-url-text"></span></div>
          </div>
          <div class="browser-page">
            <div class="browser-hero-img"></div>
            <div class="browser-heading"></div>
            <div class="browser-text w-full"></div>
            <div class="browser-text w-[85%]"></div>
            <div class="browser-text w-[70%]"></div>
            <div class="browser-cards">
              <div class="browser-card"><div class="browser-card-img"></div><div class="browser-text w-[90%]"></div></div>
              <div class="browser-card"><div class="browser-card-img"></div><div class="browser-text w-[80%]"></div></div>
            </div>
          </div>
        </div>
      </div>

      <!-- Move/resize badges -->
      <div class="s1-badge-wrap absolute pointer-events-none" style="top:4%;left:50%;width:0;z-index:20;">
        <div class="s1-badge s1-badge-move sc-badge">
          <span class="sc-badge-keys" aria-hidden="true">
            <span class="sc-badge-key">⇧</span>
            <span class="sc-badge-key">⌘</span>
          </span>
          <span class="sc-badge-copy">Left Click</span>
        </div>
        <div class="s1-badge s1-badge-resize sc-badge opacity-0">
          <span class="sc-badge-keys" aria-hidden="true">
            <span class="sc-badge-key">⇧</span>
            <span class="sc-badge-key">⌘</span>
          </span>
          <span class="sc-badge-copy">Right Click</span>
        </div>
      </div>

      <!-- Cursor -->
      <div class="s1-cursor absolute pointer-events-none" style="width:18px;height:24px;z-index:50;filter:drop-shadow(0 2px 4px rgba(0,0,0,0.5));">
        <svg viewBox="0 0 18 24" fill="none" xmlns="http://www.w3.org/2000/svg">
          <path d="M1 1L1 17.5L5.5 13.5L9 21L12 19.5L8.5 12.5L14 12L1 1Z" fill="white" stroke="black" stroke-width="0.5"/>
        </svg>
      </div>

      <!-- Resize cursor (diagonal ↖↘ for bottom-right drag) -->
      <div class="s1-resize-cursor absolute pointer-events-none opacity-0" style="width:20px;height:20px;z-index:50;filter:drop-shadow(0 2px 4px rgba(0,0,0,0.5));">
        <svg viewBox="0 0 20 20" fill="none" xmlns="http://www.w3.org/2000/svg">
          <path d="M3 3L17 17M3 3L8 3M3 3L3 8M17 17L12 17M17 17L17 12" stroke="white" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </div>
    </div>

    <!-- ────────────────────────────────────────────────── -->
    <!-- SLIDE 2 — Hotkey Tiling (9s)                      -->
    <!-- ────────────────────────────────────────────────── -->
    <div class="showcase-slide" data-slide="2" data-duration="9000">
      <!-- Single window -->
      <div class="s2-win absolute rounded-[10px] overflow-hidden" style="top:15%;left:25%;width:50%;height:70%; box-shadow:0 8px 32px rgba(0,0,0,0.4); border:1px solid rgba(255,255,255,0.08); z-index:2;">
        <div class="sc-titlebar flex items-center h-7 px-3 gap-1.5">
          <span class="w-2.5 h-2.5 rounded-full" style="background:#FF5F57;"></span>
          <span class="w-2.5 h-2.5 rounded-full" style="background:#FEBC2E;"></span>
          <span class="w-2.5 h-2.5 rounded-full" style="background:#28C840;"></span>
        </div>
        <div class="sc-win-body browser-body">
          <div class="browser-url-bar">
            <div class="browser-nav-btns"><span class="browser-nav-btn"></span><span class="browser-nav-btn"></span></div>
            <div class="browser-url-field"><span class="browser-lock">&#x1F512;</span><span class="browser-url-text"></span></div>
          </div>
          <div class="browser-page">
            <div class="browser-hero-img"></div>
            <div class="browser-heading"></div>
            <div class="browser-text w-full"></div>
            <div class="browser-text w-[85%]"></div>
            <div class="browser-text w-[70%]"></div>
          </div>
        </div>
      </div>

      <!-- Hotkey badge: 6 states, each fades in/out in sequence -->
      <div class="s2-badge-wrap absolute pointer-events-none" style="top:4%;left:50%;width:0;z-index:20;">
        <div class="s2-badge s2-badge-1 sc-badge">
          <span class="sc-badge-keys" aria-hidden="true">
            <span class="sc-badge-key">⇧</span>
            <span class="sc-badge-key">⌘</span>
            <span class="sc-badge-key">←</span>
          </span>
        </div>
        <div class="s2-badge s2-badge-2 sc-badge">
          <span class="sc-badge-keys" aria-hidden="true">
            <span class="sc-badge-key">⇧</span>
            <span class="sc-badge-key">⌘</span>
            <span class="sc-badge-key">→</span>
            <span class="sc-badge-key">↑</span>
          </span>
        </div>
        <div class="s2-badge s2-badge-3 sc-badge">
          <span class="sc-badge-keys" aria-hidden="true">
            <span class="sc-badge-key">⇧</span>
            <span class="sc-badge-key">⌘</span>
            <span class="sc-badge-key">←</span>
            <span class="sc-badge-key">↓</span>
          </span>
        </div>
        <div class="s2-badge s2-badge-4 sc-badge">
          <span class="sc-badge-keys" aria-hidden="true">
            <span class="sc-badge-key">⇧</span>
            <span class="sc-badge-key">⌘</span>
            <span class="sc-badge-key">↑</span>
          </span>
        </div>
        <div class="s2-badge s2-badge-5 sc-badge">
          <span class="sc-badge-keys" aria-hidden="true">
            <span class="sc-badge-key">⇧</span>
            <span class="sc-badge-key">⌘</span>
            <span class="sc-badge-key">→</span>
            <span class="sc-badge-key">↓</span>
          </span>
        </div>
        <div class="s2-badge s2-badge-6 sc-badge">
          <span class="sc-badge-keys" aria-hidden="true">
            <span class="sc-badge-key">⇧</span>
            <span class="sc-badge-key">⌘</span>
            <span class="sc-badge-key">F</span>
          </span>
        </div>
      </div>

      <!-- Tile zone overlays (flash during snap) -->
      <div class="s2-zone s2-zone-lh absolute rounded-lg opacity-0 pointer-events-none" style="top:2%;left:2%;width:46%;height:96%; border:2px solid var(--accent); background:rgba(166,179,204,0.10); z-index:10;"></div>
      <div class="s2-zone s2-zone-tr absolute rounded-lg opacity-0 pointer-events-none" style="top:2%;left:52%;width:46%;height:46%; border:2px solid var(--accent); background:rgba(166,179,204,0.10); z-index:10;"></div>
      <div class="s2-zone s2-zone-bl absolute rounded-lg opacity-0 pointer-events-none" style="top:52%;left:2%;width:46%;height:46%; border:2px solid var(--accent); background:rgba(166,179,204,0.10); z-index:10;"></div>
      <div class="s2-zone s2-zone-th absolute rounded-lg opacity-0 pointer-events-none" style="top:2%;left:2%;width:96%;height:46%; border:2px solid var(--accent); background:rgba(166,179,204,0.10); z-index:10;"></div>
      <div class="s2-zone s2-zone-br absolute rounded-lg opacity-0 pointer-events-none" style="top:52%;left:52%;width:46%;height:46%; border:2px solid var(--accent); background:rgba(166,179,204,0.10); z-index:10;"></div>
      <div class="s2-zone s2-zone-am absolute rounded-[10px] opacity-0 pointer-events-none" style="top:10%;left:10%;width:80%;height:80%; border:2px solid var(--accent); background:rgba(166,179,204,0.08); z-index:10;"></div>
    </div>

    <!-- ────────────────────────────────────────────────── -->
    <!-- SLIDE 3 — Predefined Layouts (10s)                -->
    <!-- ────────────────────────────────────────────────── -->
    <div class="showcase-slide" data-slide="3" data-duration="10000">
      <div class="s3-layout s3-layout-1 absolute" style="inset:12% 6% 8%;">
        <div class="s3-preview absolute" style="top:0%;left:0%;width:48.5%;height:100%;"></div>
        <div class="s3-preview absolute" style="top:0%;left:51.5%;width:48.5%;height:100%;"></div>
      </div>
      <div class="s3-layout s3-layout-2 absolute" style="inset:12% 6% 8%;">
        <div class="s3-preview absolute" style="top:0%;left:0%;width:65%;height:100%;"></div>
        <div class="s3-preview absolute" style="top:0%;left:68%;width:32%;height:100%;"></div>
      </div>
      <div class="s3-layout s3-layout-3 absolute" style="inset:12% 6% 8%;">
        <div class="s3-preview absolute" style="top:0%;left:0%;width:31%;height:100%;"></div>
        <div class="s3-preview absolute" style="top:0%;left:34.5%;width:31%;height:100%;"></div>
        <div class="s3-preview absolute" style="top:0%;left:69%;width:31%;height:100%;"></div>
      </div>
      <div class="s3-layout s3-layout-4 absolute" style="inset:12% 6% 8%;">
        <div class="s3-preview absolute" style="top:0%;left:0%;width:31%;height:48.5%;"></div>
        <div class="s3-preview absolute" style="top:51.5%;left:0%;width:31%;height:48.5%;"></div>
        <div class="s3-preview absolute" style="top:0%;left:34%;width:66%;height:100%;"></div>
      </div>
      <div class="s3-layout s3-layout-5 absolute" style="inset:12% 6% 8%;">
        <div class="s3-preview absolute" style="top:0%;left:0%;width:48.5%;height:48.5%;"></div>
        <div class="s3-preview absolute" style="top:0%;left:51.5%;width:48.5%;height:48.5%;"></div>
        <div class="s3-preview absolute" style="top:51.5%;left:0%;width:48.5%;height:48.5%;"></div>
        <div class="s3-preview absolute" style="top:51.5%;left:51.5%;width:48.5%;height:48.5%;"></div>
      </div>

      <!-- Layout badge -->
      <div class="s3-badge-wrap absolute pointer-events-none" style="top:4%;left:50%;width:0;z-index:20;">
        <div class="s3-badge s3-badge-1 sc-badge"><span class="sc-badge-copy">2 Columns</span></div>
        <div class="s3-badge s3-badge-2 sc-badge"><span class="sc-badge-copy">2/3</span></div>
        <div class="s3-badge s3-badge-3 sc-badge"><span class="sc-badge-copy">3 Columns</span></div>
