  :global(:root:not(.dark)) .browser-card-img { background: rgba(0,0,0,0.05); }

  :global(:root:not(.dark)) .editor-sidebar { background: rgba(0,0,0,0.02); border-right-color: rgba(0,0,0,0.06); }
