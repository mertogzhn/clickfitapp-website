---
---

<section class="relative pt-32 pb-20 md:pt-44 md:pb-32 overflow-hidden">
  <!-- Background gradient -->
  <div class="absolute inset-0 pointer-events-none">
    <div class="absolute top-1/4 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[600px] h-[600px] bg-accent/10 rounded-full blur-[120px]"></div>
  </div>

  <div class="relative max-w-6xl mx-auto px-6 text-center">
    <!-- Badge -->
    <div class="inline-flex items-center gap-2 px-4 py-1.5 rounded-full border border-border bg-bg-secondary text-sm text-text-secondary mb-8">
      <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <path d="M12 2C6.477 2 2 6.477 2 12s4.477 10 10 10 10-4.477 10-10S17.523 2 12 2z"/>
        <path d="M8 12l3 3 5-5"/>
      </svg>
      Free &amp; lightweight for macOS
    </div>

    <!-- Heading -->
    <h1 class="text-4xl sm:text-5xl md:text-7xl font-bold tracking-tight leading-[1.1] mb-6">
      Window management,<br />
      <span class="text-accent">effortless.</span>
    </h1>

    <!-- Subtitle -->
    <p class="text-lg md:text-xl text-text-secondary max-w-2xl mx-auto mb-10 leading-relaxed">
      Move, resize, and snap windows with your mouse and keyboard.
      ClickFit lives in your menu bar and stays out of your way.
    </p>

    <!-- CTA Buttons -->
    <div class="flex flex-col sm:flex-row items-center justify-center gap-4 mb-6">
      <a
        href="#download"
        class="inline-flex items-center gap-2 bg-accent hover:bg-accent-hover text-white font-medium px-8 py-3.5 rounded-xl transition-all shadow-lg shadow-accent-glow hover:shadow-xl hover:shadow-accent-glow"
      >
        <svg class="w-5 h-5" viewBox="0 0 24 24" fill="currentColor">
          <path d="M18.71 19.5c-.83 1.24-1.71 2.45-3.05 2.47-1.34.03-1.77-.79-3.29-.79-1.53 0-2 .77-3.27.82-1.31.05-2.3-1.32-3.14-2.53C4.25 17 2.94 12.45 4.7 9.39c.87-1.52 2.43-2.48 4.12-2.51 1.28-.02 2.5.87 3.29.87.78 0 2.26-1.07 3.8-.91.65.03 2.47.26 3.64 1.98-.09.06-2.17 1.28-2.15 3.81.03 3.02 2.65 4.03 2.68 4.04-.03.07-.42 1.44-1.38 2.83M13 3.5c.73-.83 1.94-1.46 2.94-1.5.13 1.17-.34 2.35-1.04 3.19-.69.85-1.83 1.51-2.95 1.42-.15-1.15.41-2.35 1.05-3.11z"/>
        </svg>
        Download for macOS
      </a>
      <a
        href="#features"
        class="inline-flex items-center gap-2 text-text-secondary hover:text-text-primary font-medium px-8 py-3.5 rounded-xl border border-border hover:border-text-secondary/30 transition-all"
      >
        Learn more
        <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M7 17l9.2-9.2M17 17V7.8H7.8"/>
        </svg>
      </a>
    </div>

    <!-- System requirements -->
    <p class="text-xs text-text-secondary/60">Requires macOS 14 Sonoma or later</p>

    <!-- Hero screenshot placeholder -->
    <div class="relative mt-16 mx-auto max-w-4xl">
      <div class="absolute inset-0 bg-accent/5 rounded-2xl blur-2xl"></div>
      <div class="relative rounded-2xl border border-border overflow-hidden bg-bg-secondary aspect-video flex items-center justify-center">
        <div class="text-center text-text-secondary/40">
          <svg class="w-16 h-16 mx-auto mb-3 opacity-50" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
            <rect x="2" y="3" width="20" height="14" rx="2"/>
            <path d="M8 21h8M12 17v4"/>
          </svg>
          <p class="text-sm">App screenshot placeholder</p>
        </div>
      </div>
    </div>
  </div>
</section>
