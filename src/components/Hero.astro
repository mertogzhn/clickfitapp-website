---
import HeroAnimation from './HeroAnimation.astro';
---

<section class="relative pt-32 pb-20 md:pt-44 md:pb-32 overflow-hidden">
  <!-- Background: dual offset glows -->
  <div class="absolute inset-0 pointer-events-none">
    <div class="absolute top-1/4 left-1/3 -translate-x-1/2 -translate-y-1/2 w-[500px] h-[500px] rounded-full blur-[140px]" style="background:rgba(166,179,204,0.08);"></div>
    <div class="absolute top-1/3 right-1/4 translate-x-1/4 -translate-y-1/3 w-[400px] h-[400px] rounded-full blur-[120px]" style="background:rgba(196,181,224,0.06);"></div>
  </div>

  <div class="relative max-w-6xl mx-auto px-6 text-center">
    <!-- Badge with shimmer -->
    <div class="inline-flex items-center gap-2 px-4 py-1.5 rounded-full border border-border bg-bg-secondary/60 text-sm text-text-secondary mb-8 backdrop-blur-sm overflow-hidden relative">
      <svg class="w-4 h-4 text-accent" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <path d="M12 2C6.477 2 2 6.477 2 12s4.477 10 10 10 10-4.477 10-10S17.523 2 12 2z"/>
        <path d="M8 12l3 3 5-5"/>
      </svg>
      Native macOS Window Manager
      <!-- Shimmer highlight -->
      <span class="absolute inset-0 pointer-events-none" style="background:linear-gradient(90deg,transparent,rgba(255,255,255,0.08),transparent); animation:shimmer 3s ease-in-out infinite;"></span>
    </div>

    <!-- Heading -->
    <h1 class="text-5xl sm:text-6xl md:text-[80px] font-bold tracking-[-0.03em] leading-[1.05] mb-6">
      Every window,<br />
      <span class="gradient-text">exactly where you want it.</span>
    </h1>

    <!-- Subtitle -->
    <p class="text-lg md:text-xl text-text-secondary max-w-2xl mx-auto mb-10 leading-relaxed">
      Move, resize, and snap any window with modifier-click gestures.
      A native menu bar app that stays invisible until you need it.
    </p>

    <!-- CTA Buttons -->
    <div class="flex flex-col sm:flex-row items-center justify-center gap-4 mb-6">
      <a
        href="#download"
        class="group inline-flex items-center gap-2 bg-accent hover:bg-accent-hover text-white font-medium px-8 py-3.5 rounded-xl transition-all shadow-lg shadow-accent-glow hover:shadow-xl hover:shadow-accent-glow"
      >
        <svg class="w-5 h-5" viewBox="0 0 24 24" fill="currentColor">
          <path d="M18.71 19.5c-.83 1.24-1.71 2.45-3.05 2.47-1.34.03-1.77-.79-3.29-.79-1.53 0-2 .77-3.27.82-1.31.05-2.3-1.32-3.14-2.53C4.25 17 2.94 12.45 4.7 9.39c.87-1.52 2.43-2.48 4.12-2.51 1.28-.02 2.5.87 3.29.87.78 0 2.26-1.07 3.8-.91.65.03 2.47.26 3.64 1.98-.09.06-2.17 1.28-2.15 3.81.03 3.02 2.65 4.03 2.68 4.04-.03.07-.42 1.44-1.38 2.83M13 3.5c.73-.83 1.94-1.46 2.94-1.5.13 1.17-.34 2.35-1.04 3.19-.69.85-1.83 1.51-2.95 1.42-.15-1.15.41-2.35 1.05-3.11z"/>
        </svg>
        Download for macOS
        <svg class="w-4 h-4 transition-transform group-hover:translate-y-0.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M12 5v14M5 12l7 7 7-7"/>
        </svg>
      </a>
      <a
        href="#features"
        class="inline-flex items-center gap-2 text-text-secondary hover:text-text-primary font-medium px-8 py-3.5 rounded-xl border border-border hover:border-text-secondary/30 transition-all"
      >
        Learn more
        <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M7 17l9.2-9.2M17 17V7.8H7.8"/>
        </svg>
      </a>
    </div>

    <!-- System requirements -->
    <p class="text-xs text-text-secondary/60">Requires macOS 14 Sonoma or later</p>

    <!-- Hero Animation -->
    <HeroAnimation />
  </div>
</section>
