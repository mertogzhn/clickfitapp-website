---
---

<nav class="fixed top-0 left-0 right-0 z-50 border-b border-border/50 backdrop-blur-xl bg-bg/80">
  <div class="max-w-6xl mx-auto px-6 h-16 flex items-center justify-between">
    <a href="/" class="flex items-center gap-2.5 text-text-primary font-semibold text-lg">
      <img src="/images/app-icon-light.png" alt="ClickFit" class="w-8 h-8 rounded-lg" />
      ClickFit
    </a>
    <div class="hidden sm:flex items-center gap-6">
      <a href="#features" class="text-sm text-text-secondary hover:text-text-primary transition-colors">Features</a>
      <a href="#how-it-works" class="text-sm text-text-secondary hover:text-text-primary transition-colors">How It Works</a>

      <!-- Theme toggle -->
      <button
        onclick="toggleTheme()"
        class="relative w-9 h-9 flex items-center justify-center rounded-lg text-text-secondary hover:text-text-primary hover:bg-bg-secondary/60 transition-colors"
        aria-label="Toggle theme"
      >
        <!-- Sun icon (visible in dark mode — click to go light) -->
        <svg data-theme-toggle-sun class="w-[18px] h-[18px]" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <circle cx="12" cy="12" r="5"/>
          <line x1="12" y1="1" x2="12" y2="3"/>
          <line x1="12" y1="21" x2="12" y2="23"/>
          <line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/>
          <line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/>
          <line x1="1" y1="12" x2="3" y2="12"/>
          <line x1="21" y1="12" x2="23" y2="12"/>
          <line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/>
          <line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/>
        </svg>
        <!-- Moon icon (visible in light mode — click to go dark) -->
        <svg data-theme-toggle-moon class="w-[18px] h-[18px]" style="display:none" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/>
        </svg>
      </button>

      <a href="#download" class="text-sm font-medium text-white bg-accent hover:bg-accent-hover px-4 py-2 rounded-lg transition-colors">
        Download
      </a>
    </div>
  </div>
</nav>
