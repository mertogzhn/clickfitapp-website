---
---

<!-- Animated mini-desktop demonstrating ClickFit's core value -->
<div class="hero-animation-wrapper relative mx-auto max-w-4xl mt-16" data-animate="scale-in">
  <!-- Outer glow -->
  <div class="absolute inset-0 bg-accent/5 rounded-2xl blur-2xl pointer-events-none"></div>

  <!-- Desktop surface -->
  <div class="hero-animation relative rounded-2xl overflow-hidden border border-black/[0.08] dark:border-white/[0.06]" style="aspect-ratio:16/10; contain:layout style paint;">

    <!-- Window: Browser -->
    <div class="hero-win hero-win-browser absolute rounded-[10px] overflow-hidden" style="top:8%;left:20%;width:38%;height:42%; box-shadow:0 8px 32px rgba(0,0,0,0.4); border:1px solid rgba(255,255,255,0.08); z-index:2;">
      <div class="hero-titlebar flex items-center h-7 px-3 gap-1.5">
        <span class="w-2.5 h-2.5 rounded-full" style="background:#FF5F57;"></span>
        <span class="w-2.5 h-2.5 rounded-full" style="background:#FEBC2E;"></span>
        <span class="w-2.5 h-2.5 rounded-full" style="background:#28C840;"></span>
        <span class="hero-win-title flex-1 text-center text-[10px] font-medium">Browser</span>
      </div>
      <div class="hero-win-body p-3 space-y-2">
        <div class="h-1.5 rounded-full hero-content-line w-4/5"></div>
        <div class="h-1.5 rounded-full hero-content-line w-3/5"></div>
        <div class="h-1.5 rounded-full hero-content-line w-full"></div>
        <div class="h-1.5 rounded-full hero-content-line w-2/3"></div>
        <div class="h-1.5 rounded-full hero-content-line w-4/5"></div>
      </div>
    </div>

    <!-- Window: Code Editor -->
    <div class="hero-win hero-win-editor absolute rounded-[10px] overflow-hidden" style="top:12%;left:42%;width:46%;height:70%; box-shadow:0 8px 32px rgba(0,0,0,0.4); border:1px solid rgba(255,255,255,0.08); z-index:3;">
      <div class="hero-titlebar flex items-center h-7 px-3 gap-1.5">
        <span class="w-2.5 h-2.5 rounded-full" style="background:#FF5F57;"></span>
        <span class="w-2.5 h-2.5 rounded-full" style="background:#FEBC2E;"></span>
        <span class="w-2.5 h-2.5 rounded-full" style="background:#28C840;"></span>
        <span class="hero-win-title flex-1 text-center text-[10px] font-medium">Code Editor</span>
      </div>
      <div class="hero-win-body p-3 space-y-2">
        <div class="h-1.5 rounded-full hero-content-line w-3/4"></div>
        <div class="h-1.5 rounded-full hero-content-line w-1/2"></div>
        <div class="h-1.5 rounded-full hero-content-line w-5/6"></div>
        <div class="h-1.5 rounded-full hero-content-line w-2/3"></div>
        <div class="h-1.5 rounded-full hero-content-line w-4/5"></div>
        <div class="h-1.5 rounded-full hero-content-line w-3/5"></div>
        <div class="h-1.5 rounded-full hero-content-line w-full"></div>
        <div class="h-1.5 rounded-full hero-content-line w-2/5"></div>
      </div>
    </div>

    <!-- Window: Terminal -->
    <div class="hero-win hero-win-terminal absolute rounded-[10px] overflow-hidden" style="top:54%;left:6%;width:34%;height:36%; box-shadow:0 8px 32px rgba(0,0,0,0.4); border:1px solid rgba(255,255,255,0.08); z-index:1;">
      <div class="hero-titlebar flex items-center h-7 px-3 gap-1.5">
        <span class="w-2.5 h-2.5 rounded-full" style="background:#FF5F57;"></span>
        <span class="w-2.5 h-2.5 rounded-full" style="background:#FEBC2E;"></span>
        <span class="w-2.5 h-2.5 rounded-full" style="background:#28C840;"></span>
        <span class="hero-win-title flex-1 text-center text-[10px] font-medium">Terminal</span>
      </div>
      <div class="hero-win-body p-3 space-y-1.5">
        <div class="h-1.5 rounded-full hero-content-line w-2/3"></div>
        <div class="h-1.5 rounded-full hero-content-line w-1/2"></div>
        <div class="h-1.5 rounded-full hero-content-line w-3/4"></div>
      </div>
    </div>

    <!-- Tile overlays (one per zone, shown during respective snap) -->
    <div class="hero-tile-overlay hero-tile-ol-tl absolute rounded-lg opacity-0 pointer-events-none" style="top:2%;left:2%;width:46%;height:46%; border:2px solid var(--accent); background:rgba(166,179,204,0.10);"></div>
    <div class="hero-tile-overlay hero-tile-ol-bl absolute rounded-lg opacity-0 pointer-events-none" style="top:52%;left:2%;width:46%;height:46%; border:2px solid var(--accent); background:rgba(166,179,204,0.10);"></div>
    <div class="hero-tile-overlay hero-tile-ol-rh absolute rounded-lg opacity-0 pointer-events-none" style="top:2%;left:52%;width:46%;height:96%; border:2px solid var(--accent); background:rgba(166,179,204,0.10);"></div>

    <!-- Snap indicator line -->
    <div class="hero-snap-line absolute opacity-0 pointer-events-none" style="width:2px; background:var(--accent); box-shadow:0 0 8px var(--accent-glow);"></div>

    <!-- Cursor -->
    <div class="hero-cursor absolute pointer-events-none" style="width:18px;height:24px;z-index:50;filter:drop-shadow(0 2px 4px rgba(0,0,0,0.5));">
      <svg viewBox="0 0 18 24" fill="none" xmlns="http://www.w3.org/2000/svg">
        <path d="M1 1L1 17.5L5.5 13.5L9 21L12 19.5L8.5 12.5L14 12L1 1Z" fill="white" stroke="black" stroke-width="0.5"/>
      </svg>
    </div>



    <!-- Resize cursor (bidirectional arrow, hidden by default) -->
    <div class="hero-resize-cursor absolute pointer-events-none opacity-0" style="width:20px;height:20px;z-index:50;filter:drop-shadow(0 2px 4px rgba(0,0,0,0.5));">
      <svg viewBox="0 0 20 20" fill="none" xmlns="http://www.w3.org/2000/svg">
        <path d="M1 10H19M1 10L5 6M1 10L5 14M19 10L15 6M19 10L15 14" stroke="white" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
    </div>
  </div>

  <!-- Mobile fallback: static tiled layout -->
  <div class="hero-animation-mobile hidden">
    <div class="relative rounded-2xl overflow-hidden border border-black/[0.08] dark:border-white/[0.06] p-6 hero-desktop-bg">
      <div class="grid grid-cols-2 gap-2 aspect-video">
        <div class="rounded-lg hero-win-body" style="border:1px solid var(--border);"></div>
        <div class="rounded-lg row-span-2 hero-win-body" style="border:1px solid var(--border);"></div>
        <div class="rounded-lg hero-win-body" style="border:1px solid var(--border);"></div>
      </div>
    </div>
  </div>
</div>

<style>
  /* Show/hide based on viewport */
  @media (max-width: 767px) {
    .hero-animation { display: none; }
    .hero-animation-mobile { display: block; }
  }
  @media (min-width: 768px) {
    .hero-animation-mobile { display: none !important; }
  }

  /* Tablet scaling */
  @media (min-width: 768px) and (max-width: 1024px) {
    .hero-animation { transform: scale(0.8); transform-origin: top center; }
  }

  /* ── Animation choreography: ~15s total loop ── */
  .hero-animation {
    --dur: 15s;
  }

  /* Performance hints */
  .hero-win-browser,
  .hero-win-editor,
  .hero-win-terminal {
    will-change: top, left, width, height, border-radius, opacity;
  }
  .hero-cursor,
  .hero-resize-cursor {
    will-change: transform, opacity;
  }
  .hero-tile-ol-tl,
  .hero-tile-ol-bl,
  .hero-tile-ol-rh,
  .hero-snap-line {
    will-change: opacity;
  }

  /* ── Light/Dark theme for hero animation ── */
  .hero-animation { background: #0D1017; }
  .hero-titlebar { background: #1A1F2E; }
  .hero-win-title { color: rgba(255,255,255,0.3); }
  .hero-win-body { background: #141922; }
  .hero-win-terminal .hero-win-body { background: #0F1319; }
  .hero-win-editor .hero-win-body { background: #12161F; }
  .hero-content-line { background: rgba(255,255,255,0.06); }
  .hero-desktop-bg { background: #0D1017; }
  .hero-cursor svg path { fill: white; stroke: black; }
  .hero-resize-cursor svg path { stroke: white; }

  :global(:root:not(.dark)) .hero-animation { background: #E8E8ED; }
  :global(:root:not(.dark)) .hero-titlebar { background: #D1D1D6; }
  :global(:root:not(.dark)) .hero-win-title { color: rgba(0,0,0,0.4); }
  :global(:root:not(.dark)) .hero-win-body { background: #F5F5F7; }
  :global(:root:not(.dark)) .hero-win-terminal .hero-win-body { background: #EBEBF0; }
  :global(:root:not(.dark)) .hero-win-editor .hero-win-body { background: #F0F0F5; }
  :global(:root:not(.dark)) .hero-content-line { background: rgba(0,0,0,0.06); }
  :global(:root:not(.dark)) .hero-desktop-bg { background: #E8E8ED; }
  :global(:root:not(.dark)) .hero-cursor svg path { fill: black; stroke: white; }
  :global(:root:not(.dark)) .hero-resize-cursor svg path { stroke: black; }
  :global(:root:not(.dark)) .hero-win-browser,
  :global(:root:not(.dark)) .hero-win-editor,
  :global(:root:not(.dark)) .hero-win-terminal {
    box-shadow: 0 8px 32px rgba(0,0,0,0.12) !important;
    border-color: rgba(0,0,0,0.1) !important;
  }

  /* === CURSOR animation (position + opacity combined) === */
  .hero-cursor {
    animation: cursor-anim var(--dur) cubic-bezier(0.4,0,0.2,1) infinite;
    top: 50%;
    left: 50%;
  }

  @keyframes cursor-anim {
    0%    { transform: translate(0, 0); opacity: 1; }
    5%    { transform: translate(0, 0); opacity: 1; }
    /* Arrive at browser CENTER */
    10%   { transform: translate(-99px, -118px); opacity: 1; }
    /* Single smooth drag toward top-left */
    19%   { transform: translate(-269px, -157px); opacity: 1; }
    /* Browser snaps — cursor jumps to TL quarter center */
    20%   { transform: translate(-224px, -140px); opacity: 1; }
    21%   { transform: translate(-224px, -140px); opacity: 1; }
    /* Move to terminal CENTER */
    25%   { transform: translate(-242px, 123px); opacity: 1; }
    /* Single smooth drag toward bottom-left */
    34%   { transform: translate(-287px, 106px); opacity: 1; }
    /* Terminal snaps — cursor jumps to BL quarter center */
    35%   { transform: translate(-224px, 140px); opacity: 1; }
    36%   { transform: translate(-224px, 140px); opacity: 1; }
    /* Move to editor CENTER */
    40%   { transform: translate(134px, -17px); opacity: 1; }
    /* Single smooth drag toward right half */
    49%   { transform: translate(197px, -73px); opacity: 1; }
    /* Editor snaps — cursor jumps to right-half center */
    50%   { transform: translate(224px, 0px); opacity: 1; }
    51%   { transform: translate(224px, 0px); opacity: 1; }
    /* Move to center border */
    55%   { transform: translate(0, 0); opacity: 1; }
    /* Hide for resize cursor handoff */
    56%   { transform: translate(0, 0); opacity: 0; }
    78%   { transform: translate(0, 0); opacity: 0; }
    /* Reappear at center */
    79%   { transform: translate(0, 0); opacity: 1; }
    87%   { transform: translate(0, 0); opacity: 1; }
    100%  { transform: translate(0, 0); opacity: 1; }
  }



  /* === BROWSER WINDOW animation === */
  .hero-win-browser {
    animation: browser-move var(--dur) cubic-bezier(0.4,0,0.2,1) infinite;
  }

  @keyframes browser-move {
    0%    { top: 8%; left: 20%; width: 38%; height: 42%; border-radius: 10px; }
    10%   { top: 8%; left: 20%; width: 38%; height: 42%; border-radius: 10px; }
    /* Single smooth drag — keeps original size */
    19%   { top: 1%; left: 1%; width: 38%; height: 42%; border-radius: 6px; }
    /* Snap to TL quarter */
    20%   { top: 0%; left: 0%; width: 50%; height: 50%; border-radius: 0; }
    57%   { top: 0%; left: 0%; width: 50%; height: 50%; border-radius: 0; }
    /* Coupled resize — browser grows */
    68%   { top: 0%; left: 0%; width: 58%; height: 50%; border-radius: 0; }
    78%   { top: 0%; left: 0%; width: 58%; height: 50%; border-radius: 0; }
    /* Reset to scattered */
    87%   { top: 8%; left: 20%; width: 38%; height: 42%; border-radius: 10px; }
    100%  { top: 8%; left: 20%; width: 38%; height: 42%; border-radius: 10px; }
  }

  /* === CODE EDITOR animation === */
  .hero-win-editor {
    animation: editor-move var(--dur) cubic-bezier(0.4,0,0.2,1) infinite;
  }

  @keyframes editor-move {
    0%    { top: 12%; left: 42%; width: 46%; height: 70%; border-radius: 10px; }
    40%   { top: 12%; left: 42%; width: 46%; height: 70%; border-radius: 10px; }
    /* Single smooth drag — keeps original size */
    49%   { top: 2%; left: 49%; width: 46%; height: 70%; border-radius: 6px; }
    /* Snap to right half */
    50%   { top: 0%; left: 50%; width: 50%; height: 100%; border-radius: 0; }
    57%   { top: 0%; left: 50%; width: 50%; height: 100%; border-radius: 0; }
    /* Coupled resize — editor shrinks */
    68%   { top: 0%; left: 58%; width: 42%; height: 100%; border-radius: 0; }
    78%   { top: 0%; left: 58%; width: 42%; height: 100%; border-radius: 0; }
    /* Reset to scattered */
    87%   { top: 12%; left: 42%; width: 46%; height: 70%; border-radius: 10px; }
    100%  { top: 12%; left: 42%; width: 46%; height: 70%; border-radius: 10px; }
  }

  /* === TERMINAL animation (real position movement) === */
  .hero-win-terminal {
    animation: terminal-move var(--dur) cubic-bezier(0.4,0,0.2,1) infinite;
  }

  @keyframes terminal-move {
    0%    { top: 54%; left: 6%; width: 34%; height: 36%; border-radius: 10px; }
    25%   { top: 54%; left: 6%; width: 34%; height: 36%; border-radius: 10px; }
    /* Single smooth drag — keeps original size */
    34%   { top: 51%; left: 1%; width: 34%; height: 36%; border-radius: 6px; }
    /* Snap to BL quarter */
    35%   { top: 50%; left: 0%; width: 50%; height: 50%; border-radius: 0; }
    57%   { top: 50%; left: 0%; width: 50%; height: 50%; border-radius: 0; }
    /* Coupled resize — terminal grows */
    68%   { top: 50%; left: 0%; width: 58%; height: 50%; border-radius: 0; }
    78%   { top: 50%; left: 0%; width: 58%; height: 50%; border-radius: 0; }
    /* Reset to scattered */
    87%   { top: 54%; left: 6%; width: 34%; height: 36%; border-radius: 10px; }
    100%  { top: 54%; left: 6%; width: 34%; height: 36%; border-radius: 10px; }
  }

  /* === TILE OVERLAY: Top-Left Quarter === */
  .hero-tile-ol-tl {
    animation: tile-ol-tl var(--dur) ease infinite;
  }
  @keyframes tile-ol-tl {
    0%    { opacity: 0; }
    15%   { opacity: 0; }
    17%   { opacity: 1; }
    19%   { opacity: 1; }
    21%   { opacity: 0; }
    100%  { opacity: 0; }
  }

  /* === TILE OVERLAY: Bottom-Left Quarter === */
  .hero-tile-ol-bl {
    animation: tile-ol-bl var(--dur) ease infinite;
  }
  @keyframes tile-ol-bl {
    0%    { opacity: 0; }
    30%   { opacity: 0; }
    32%   { opacity: 1; }
    34%   { opacity: 1; }
    36%   { opacity: 0; }
    100%  { opacity: 0; }
  }

  /* === TILE OVERLAY: Right Half === */
  .hero-tile-ol-rh {
    animation: tile-ol-rh var(--dur) ease infinite;
  }
  @keyframes tile-ol-rh {
    0%    { opacity: 0; }
    45%   { opacity: 0; }
    47%   { opacity: 1; }
    49%   { opacity: 1; }
    51%   { opacity: 0; }
    100%  { opacity: 0; }
  }

  /* === SNAP LINE (vertical border between left & right halves) === */
  .hero-snap-line {
    animation: snap-line var(--dur) ease infinite;
  }

  @keyframes snap-line {
    0%    { opacity: 0; top: 0%; height: 100%; left: 50%; }
    52%   { opacity: 0; top: 0%; height: 100%; left: 50%; }
    54%   { opacity: 1; top: 0%; height: 100%; left: 50%; }
    57%   { opacity: 1; top: 0%; height: 100%; left: 50%; }
    68%   { opacity: 1; top: 0%; height: 100%; left: 58%; }
    75%   { opacity: 1; top: 0%; height: 100%; left: 58%; }
    78%   { opacity: 0; top: 0%; height: 100%; left: 58%; }
    100%  { opacity: 0; top: 0%; height: 100%; left: 50%; }
  }

  /* === RESIZE CURSOR (appears during coupled resize) === */
  .hero-resize-cursor {
    animation: resize-anim var(--dur) cubic-bezier(0.4,0,0.2,1) infinite;
    top: 50%;
    left: 50%;
  }

  @keyframes resize-anim {
    0%    { transform: translate(0, 0); opacity: 0; }
    55%   { transform: translate(0, 0); opacity: 0; }
    56%   { transform: translate(0, 0); opacity: 1; }
    57%   { transform: translate(0, 0); opacity: 1; }
    68%   { transform: translate(72px, 0); opacity: 1; }
    75%   { transform: translate(72px, 0); opacity: 1; }
    77%   { transform: translate(72px, 0); opacity: 0; }
    100%  { transform: translate(0, 0); opacity: 0; }
  }
</style>

<script is:inline>
  // Pause animation when not in viewport; respect reduced motion
  (function() {
    var wrapper = document.querySelector('.hero-animation');
    if (!wrapper) return;

    // Reduced motion: show static end-state
    if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
      wrapper.style.animationPlayState = 'paused';
      var cursor = wrapper.querySelector('.hero-cursor');
      if (cursor) cursor.style.display = 'none';
      return;
    }

    var observer = new IntersectionObserver(function(entries) {
      entries.forEach(function(entry) {
        var state = entry.isIntersecting ? 'running' : 'paused';
        wrapper.querySelectorAll('[class*="hero-"]').forEach(function(el) {
          el.style.animationPlayState = state;
        });
      });
    }, { threshold: 0.2 });
    observer.observe(wrapper);
  })();
</script>
