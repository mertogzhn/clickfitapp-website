---
---

<!-- Animated mini-desktop demonstrating ClickFit's core value -->
<div class="hero-animation-wrapper relative mx-auto max-w-4xl mt-16" data-animate="scale-in">
  <!-- Outer glow -->
  <div class="absolute inset-0 bg-accent/5 rounded-2xl blur-2xl pointer-events-none"></div>

  <!-- Desktop surface -->
  <div class="hero-animation relative rounded-2xl overflow-hidden border border-black/[0.08] dark:border-white/[0.06]" style="aspect-ratio:16/10; contain:layout style paint;">

    <!-- Window: Browser -->
    <div class="hero-win hero-win-browser absolute rounded-[10px] overflow-hidden" style="top:8%;left:20%;width:38%;height:42%; box-shadow:0 8px 32px rgba(0,0,0,0.4); border:1px solid rgba(255,255,255,0.08); z-index:2;">
      <div class="hero-titlebar flex items-center h-7 px-3 gap-1.5">
        <span class="w-2.5 h-2.5 rounded-full" style="background:#FF5F57;"></span>
        <span class="w-2.5 h-2.5 rounded-full" style="background:#FEBC2E;"></span>
        <span class="w-2.5 h-2.5 rounded-full" style="background:#28C840;"></span>
      </div>
      <div class="hero-win-body browser-body">
        <!-- URL bar -->
        <div class="browser-url-bar">
          <div class="browser-nav-btns">
            <span class="browser-nav-btn"></span>
            <span class="browser-nav-btn"></span>
          </div>
          <div class="browser-url-field">
            <span class="browser-lock">&#x1F512;</span>
            <span class="browser-url-text"></span>
          </div>
        </div>
        <!-- Page content -->
        <div class="browser-page">
          <!-- Hero image placeholder -->
          <div class="browser-hero-img"></div>
          <!-- Heading -->
          <div class="browser-heading"></div>
          <!-- Text lines -->
          <div class="browser-text w-full"></div>
          <div class="browser-text w-[85%]"></div>
          <div class="browser-text w-[70%]"></div>
          <!-- Two column cards -->
          <div class="browser-cards">
            <div class="browser-card">
              <div class="browser-card-img"></div>
              <div class="browser-text w-[90%]"></div>
              <div class="browser-text w-[60%]"></div>
            </div>
            <div class="browser-card">
              <div class="browser-card-img"></div>
              <div class="browser-text w-[80%]"></div>
              <div class="browser-text w-[50%]"></div>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- Window: Code Editor -->
    <div class="hero-win hero-win-editor absolute rounded-[10px] overflow-hidden" style="top:12%;left:42%;width:46%;height:70%; box-shadow:0 8px 32px rgba(0,0,0,0.4); border:1px solid rgba(255,255,255,0.08); z-index:3;">
      <div class="hero-titlebar flex items-center h-7 px-3 gap-1.5">
        <span class="w-2.5 h-2.5 rounded-full" style="background:#FF5F57;"></span>
        <span class="w-2.5 h-2.5 rounded-full" style="background:#FEBC2E;"></span>
        <span class="w-2.5 h-2.5 rounded-full" style="background:#28C840;"></span>
      </div>
      <div class="hero-win-body editor-body">
        <!-- Sidebar: file explorer -->
        <div class="editor-sidebar">
          <div class="editor-section-head"></div>
          <div class="editor-file active"></div>
          <div class="editor-file"></div>
          <div class="editor-file indent"></div>
          <div class="editor-file indent"></div>
          <div class="editor-file indent"></div>
          <div class="editor-file"></div>
          <div class="editor-file indent"></div>
          <div class="editor-file indent"></div>
        </div>
        <!-- Code area: line numbers + colored blocks -->
        <div class="editor-code">
          <div class="code-line"><span class="ln-gutter"></span><span class="code-block kw-block" style="width:18%"></span> <span class="code-block str-block" style="width:28%"></span></div>
          <div class="code-line"><span class="ln-gutter"></span></div>
          <div class="code-line"><span class="ln-gutter"></span><span class="code-block kw-block" style="width:14%"></span> <span class="code-block type-block" style="width:32%"></span> <span class="code-block br-block" style="width:4%"></span></div>
          <div class="code-line"><span class="ln-gutter"></span><span class="code-indent"></span><span class="code-block kw-block" style="width:12%"></span> <span class="code-block var-block" style="width:22%"></span><span class="code-block p-block" style="width:3%"></span> <span class="code-block type-block" style="width:20%"></span></div>
          <div class="code-line"><span class="ln-gutter"></span><span class="code-indent"></span><span class="code-block kw-block" style="width:12%"></span> <span class="code-block var-block" style="width:16%"></span><span class="code-block p-block" style="width:3%"></span> <span class="code-block type-block" style="width:18%"></span></div>
          <div class="code-line"><span class="ln-gutter"></span></div>
          <div class="code-line"><span class="ln-gutter"></span><span class="code-indent"></span><span class="code-block kw-block" style="width:14%"></span> <span class="code-block fn-block" style="width:18%"></span><span class="code-block p-block" style="width:6%"></span> <span class="code-block br-block" style="width:4%"></span></div>
          <div class="code-line"><span class="ln-gutter"></span><span class="code-indent"></span><span class="code-indent"></span><span class="code-block var-block" style="width:22%"></span> <span class="code-block p-block" style="width:4%"></span> <span class="code-block var-block" style="width:16%"></span></div>
          <div class="code-line"><span class="ln-gutter"></span><span class="code-indent"></span><span class="code-indent"></span><span class="code-block fn-block" style="width:26%"></span><span class="code-block p-block" style="width:6%"></span></div>
          <div class="code-line"><span class="ln-gutter"></span><span class="code-indent"></span><span class="code-block br-block" style="width:4%"></span></div>
          <div class="code-line"><span class="ln-gutter"></span></div>
          <div class="code-line"><span class="ln-gutter"></span><span class="code-indent"></span><span class="code-block kw-block" style="width:14%"></span> <span class="code-block fn-block" style="width:20%"></span><span class="code-block p-block" style="width:8%"></span> <span class="code-block br-block" style="width:4%"></span></div>
          <div class="code-line"><span class="ln-gutter"></span><span class="code-indent"></span><span class="code-indent"></span><span class="code-block kw-block" style="width:12%"></span> <span class="code-block var-block" style="width:18%"></span> <span class="code-block p-block" style="width:4%"></span> <span class="code-block fn-block" style="width:22%"></span></div>
          <div class="code-line"><span class="ln-gutter"></span><span class="code-indent"></span><span class="code-indent"></span><span class="code-block var-block" style="width:16%"></span> <span class="code-block p-block" style="width:4%"></span> <span class="code-block var-block" style="width:14%"></span></div>
          <div class="code-line"><span class="ln-gutter"></span><span class="code-indent"></span><span class="code-block br-block" style="width:4%"></span></div>
          <div class="code-line"><span class="ln-gutter"></span><span class="code-block br-block" style="width:4%"></span></div>
        </div>
      </div>
    </div>

    <!-- Window: Terminal -->
    <div class="hero-win hero-win-terminal absolute rounded-[10px] overflow-hidden" style="top:54%;left:6%;width:34%;height:36%; box-shadow:0 8px 32px rgba(0,0,0,0.4); border:1px solid rgba(255,255,255,0.08); z-index:1;">
      <div class="hero-titlebar flex items-center h-7 px-3 gap-1.5">
        <span class="w-2.5 h-2.5 rounded-full" style="background:#FF5F57;"></span>
        <span class="w-2.5 h-2.5 rounded-full" style="background:#FEBC2E;"></span>
        <span class="w-2.5 h-2.5 rounded-full" style="background:#28C840;"></span>
      </div>
      <div class="hero-win-body terminal-body">
        <div class="term-line"><span class="term-prompt-block"></span> <span class="term-cmd-block" style="width:38%"></span></div>
        <div class="term-line"><span class="term-out-block" style="width:52%"></span></div>
        <div class="term-line"><span class="term-out-block" style="width:60%"></span></div>
        <div class="term-line"></div>
        <div class="term-line"><span class="term-prompt-block"></span> <span class="term-cmd-block" style="width:30%"></span></div>
        <div class="term-line"><span class="term-out-block term-green-block" style="width:55%"></span></div>
        <div class="term-line"><span class="term-out-block term-green-block" style="width:48%"></span></div>
        <div class="term-line"></div>
        <div class="term-line"><span class="term-prompt-block"></span> <span class="term-cursor-block"></span></div>
      </div>
    </div>

    <!-- Tile overlays (one per zone, shown during respective snap) -->
    <div class="hero-tile-overlay hero-tile-ol-tl absolute rounded-lg opacity-0 pointer-events-none" style="top:2%;left:2%;width:46%;height:46%; border:2px solid var(--accent); background:rgba(166,179,204,0.10); z-index:10;"></div>
    <div class="hero-tile-overlay hero-tile-ol-bl absolute rounded-lg opacity-0 pointer-events-none" style="top:52%;left:2%;width:46%;height:46%; border:2px solid var(--accent); background:rgba(166,179,204,0.10); z-index:10;"></div>
    <div class="hero-tile-overlay hero-tile-ol-rh absolute rounded-lg opacity-0 pointer-events-none" style="top:2%;left:52%;width:46%;height:96%; border:2px solid var(--accent); background:rgba(166,179,204,0.10); z-index:10;"></div>

    <!-- Cursor -->
    <div class="hero-cursor absolute pointer-events-none" style="width:18px;height:24px;z-index:50;filter:drop-shadow(0 2px 4px rgba(0,0,0,0.5));">
      <svg viewBox="0 0 18 24" fill="none" xmlns="http://www.w3.org/2000/svg">
        <path d="M1 1L1 17.5L5.5 13.5L9 21L12 19.5L8.5 12.5L14 12L1 1Z" fill="white" stroke="black" stroke-width="0.5"/>
      </svg>
    </div>



    <!-- Resize cursor (bidirectional arrow, hidden by default) -->
    <div class="hero-resize-cursor absolute pointer-events-none opacity-0" style="width:20px;height:20px;z-index:50;filter:drop-shadow(0 2px 4px rgba(0,0,0,0.5));">
      <svg viewBox="0 0 20 20" fill="none" xmlns="http://www.w3.org/2000/svg">
        <path d="M1 10H19M1 10L5 6M1 10L5 14M19 10L15 6M19 10L15 14" stroke="white" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
    </div>
  </div>

  <!-- Mobile fallback: static tiled layout -->
  <div class="hero-animation-mobile hidden">
    <div class="relative rounded-2xl overflow-hidden border border-black/[0.08] dark:border-white/[0.06] p-6 hero-desktop-bg">
      <div class="grid grid-cols-2 gap-2 aspect-video">
        <div class="rounded-lg hero-win-body" style="border:1px solid var(--border);"></div>
        <div class="rounded-lg row-span-2 hero-win-body" style="border:1px solid var(--border);"></div>
        <div class="rounded-lg hero-win-body" style="border:1px solid var(--border);"></div>
      </div>
    </div>
  </div>
</div>

<style>
  /* Show/hide based on viewport */
  @media (max-width: 767px) {
    .hero-animation { display: none; }
    .hero-animation-mobile { display: block; }
  }
  @media (min-width: 768px) {
    .hero-animation-mobile { display: none !important; }
  }

  /* Tablet scaling */
  @media (min-width: 768px) and (max-width: 1024px) {
    .hero-animation { transform: scale(0.8); transform-origin: top center; }
  }

  /* ── Animation choreography: ~15s total loop ── */
  .hero-animation {
    --dur: 15s;
  }

  /* Performance hints */
  .hero-win-browser,
  .hero-win-editor,
  .hero-win-terminal {
    will-change: top, left, width, height, border-radius, opacity;
  }
  .hero-cursor,
  .hero-resize-cursor {
    will-change: transform, opacity;
  }
  .hero-tile-ol-tl,
  .hero-tile-ol-bl,
  .hero-tile-ol-rh {
    will-change: opacity;
  }

  /* ── Light/Dark theme for hero animation ── */
  .hero-animation { background: #0D1017; }
  .hero-titlebar { background: #1A1F2E; }
  .hero-win-body { background: #141922; }
  .hero-win-terminal .hero-win-body { background: #0F1319; }
  .hero-win-editor .hero-win-body { background: #12161F; }
  .hero-content-line { background: rgba(255,255,255,0.06); }
  .hero-desktop-bg { background: #0D1017; }

  /* ── Browser window content ── */
  .browser-body { padding: 0; display: flex; flex-direction: column; height: calc(100% - 28px); overflow: hidden; }
  .browser-url-bar { display: flex; align-items: center; gap: 4px; padding: 3px 6px; background: rgba(255,255,255,0.03); border-bottom: 1px solid rgba(255,255,255,0.04); }
  .browser-nav-btns { display: flex; gap: 2px; }
  .browser-nav-btn { width: 6px; height: 6px; border-radius: 2px; background: rgba(255,255,255,0.08); }
  .browser-url-field { flex: 1; display: flex; align-items: center; gap: 3px; background: rgba(255,255,255,0.04); border-radius: 4px; padding: 2px 5px; height: 14px; }
  .browser-lock { font-size: 6px; opacity: 0.3; line-height: 1; }
  .browser-url-text { height: 3px; width: 55%; border-radius: 2px; background: rgba(255,255,255,0.08); }
  .browser-page { flex: 1; padding: 6px; overflow: hidden; }
  .browser-hero-img { width: 100%; height: 28%; border-radius: 3px; background: linear-gradient(135deg, rgba(166,179,204,0.12) 0%, rgba(166,179,204,0.06) 100%); margin-bottom: 5px; }
  .browser-heading { height: 5px; width: 45%; border-radius: 2px; background: rgba(255,255,255,0.12); margin-bottom: 5px; }
  .browser-text { height: 3px; border-radius: 2px; background: rgba(255,255,255,0.06); margin-bottom: 3px; }
  .browser-cards { display: grid; grid-template-columns: 1fr 1fr; gap: 4px; margin-top: 5px; }
  .browser-card { background: rgba(255,255,255,0.02); border-radius: 3px; padding: 4px; border: 1px solid rgba(255,255,255,0.03); }
  .browser-card-img { width: 100%; height: 14px; border-radius: 2px; background: rgba(166,179,204,0.08); margin-bottom: 3px; }

  /* ── Code Editor content ── */
  .editor-body { padding: 0; display: flex; height: calc(100% - 28px); overflow: hidden; }
  .editor-sidebar { width: 22%; padding: 5px 4px; background: rgba(255,255,255,0.015); border-right: 1px solid rgba(255,255,255,0.04); display: flex; flex-direction: column; gap: 2px; }
  .editor-section-head { height: 3px; width: 45%; border-radius: 2px; background: rgba(255,255,255,0.1); margin-bottom: 3px; }
  .editor-file { height: 3.5px; border-radius: 2px; background: rgba(255,255,255,0.05); width: 75%; }
  .editor-file.active { background: rgba(166,179,204,0.2); }
  .editor-file.indent { margin-left: 7px; width: 60%; }
  .editor-code { flex: 1; padding: 5px 0; overflow: hidden; }
  .code-line { display: flex; align-items: center; padding: 0 5px; height: 10px; gap: 3px; }
  .ln-gutter { width: 10px; height: 3px; border-radius: 1px; background: rgba(255,255,255,0.07); flex-shrink: 0; margin-right: 6px; }
  .code-indent { width: 8px; flex-shrink: 0; }
  .code-block { height: 3.5px; border-radius: 1.5px; display: inline-block; flex-shrink: 0; }
  .kw-block { background: rgba(255,122,178,0.5); }
  .str-block { background: rgba(255,129,112,0.4); }
  .type-block { background: rgba(172,242,228,0.35); }
  .fn-block { background: rgba(103,183,164,0.4); }
  .var-block { background: rgba(120,194,179,0.3); }
  .br-block { background: rgba(255,255,255,0.15); }
  .p-block { background: rgba(255,255,255,0.1); }

  /* ── Terminal content ── */
  .terminal-body { padding: 7px 8px; height: calc(100% - 28px); overflow: hidden; display: flex; flex-direction: column; gap: 0; }
  .term-line { display: flex; align-items: center; gap: 4px; height: 10px; }
  .term-prompt-block { width: 5px; height: 5px; border-radius: 1px; background: #28C840; opacity: 0.7; flex-shrink: 0; }
  .term-cmd-block { height: 3px; border-radius: 1.5px; background: rgba(255,255,255,0.12); }
  .term-out-block { height: 3px; border-radius: 1.5px; background: rgba(255,255,255,0.06); }
  .term-green-block { background: rgba(40,200,64,0.2); }
  .term-cursor-block { width: 6px; height: 8px; border-radius: 1px; background: rgba(255,255,255,0.25); animation: blink-cursor 1s step-end infinite; }
  @keyframes blink-cursor { 0%, 50% { opacity: 1; } 51%, 100% { opacity: 0; } }
  .hero-cursor svg path { fill: white; stroke: black; }
  .hero-resize-cursor svg path { stroke: white; }

  :global(:root:not(.dark)) .hero-animation { background: #E8E8ED; }
  :global(:root:not(.dark)) .hero-titlebar { background: #D1D1D6; }
  :global(:root:not(.dark)) .hero-win-body { background: #F5F5F7; }
  :global(:root:not(.dark)) .hero-win-terminal .hero-win-body { background: #EBEBF0; }
  :global(:root:not(.dark)) .hero-win-editor .hero-win-body { background: #F0F0F5; }
  :global(:root:not(.dark)) .hero-content-line { background: rgba(0,0,0,0.06); }
  :global(:root:not(.dark)) .hero-desktop-bg { background: #E8E8ED; }

  /* ── Light theme: Browser ── */
  :global(:root:not(.dark)) .browser-url-bar { background: rgba(0,0,0,0.03); border-bottom-color: rgba(0,0,0,0.06); }
  :global(:root:not(.dark)) .browser-nav-btn { background: rgba(0,0,0,0.1); }
  :global(:root:not(.dark)) .browser-url-field { background: rgba(0,0,0,0.04); }
  :global(:root:not(.dark)) .browser-url-text { background: rgba(0,0,0,0.1); }
  :global(:root:not(.dark)) .browser-hero-img { background: linear-gradient(135deg, rgba(0,0,0,0.06) 0%, rgba(0,0,0,0.03) 100%); }
  :global(:root:not(.dark)) .browser-heading { background: rgba(0,0,0,0.14); }
  :global(:root:not(.dark)) .browser-text { background: rgba(0,0,0,0.06); }
  :global(:root:not(.dark)) .browser-card { background: rgba(0,0,0,0.02); border-color: rgba(0,0,0,0.05); }
  :global(:root:not(.dark)) .browser-card-img { background: rgba(0,0,0,0.05); }

  /* ── Light theme: Code Editor ── */
  :global(:root:not(.dark)) .editor-sidebar { background: rgba(0,0,0,0.02); border-right-color: rgba(0,0,0,0.06); }
  :global(:root:not(.dark)) .editor-section-head { background: rgba(0,0,0,0.12); }
  :global(:root:not(.dark)) .editor-file { background: rgba(0,0,0,0.07); }
  :global(:root:not(.dark)) .editor-file.active { background: rgba(0,80,200,0.18); }
  :global(:root:not(.dark)) .ln-gutter { background: rgba(0,0,0,0.08); }
  :global(:root:not(.dark)) .kw-block { background: rgba(173,61,164,0.4); }
  :global(:root:not(.dark)) .str-block { background: rgba(209,47,27,0.3); }
  :global(:root:not(.dark)) .type-block { background: rgba(62,128,135,0.3); }
  :global(:root:not(.dark)) .fn-block { background: rgba(50,109,116,0.35); }
  :global(:root:not(.dark)) .var-block { background: rgba(75,143,140,0.25); }
  :global(:root:not(.dark)) .br-block { background: rgba(0,0,0,0.12); }
  :global(:root:not(.dark)) .p-block { background: rgba(0,0,0,0.08); }

  /* ── Light theme: Terminal ── */
  :global(:root:not(.dark)) .term-prompt-block { background: #28A745; }
  :global(:root:not(.dark)) .term-cmd-block { background: rgba(0,0,0,0.1); }
  :global(:root:not(.dark)) .term-out-block { background: rgba(0,0,0,0.06); }
  :global(:root:not(.dark)) .term-green-block { background: rgba(40,167,69,0.18); }
  :global(:root:not(.dark)) .term-cursor-block { background: rgba(0,0,0,0.2); }
  :global(:root:not(.dark)) .hero-cursor svg path { fill: black; stroke: white; }
  :global(:root:not(.dark)) .hero-resize-cursor svg path { stroke: black; }
  :global(:root:not(.dark)) .hero-win-browser,
  :global(:root:not(.dark)) .hero-win-editor,
  :global(:root:not(.dark)) .hero-win-terminal {
    box-shadow: 0 8px 32px rgba(0,0,0,0.12) !important;
    border-color: rgba(0,0,0,0.1) !important;
  }

  /* === CURSOR animation (position + opacity combined) === */
  .hero-cursor {
    animation: cursor-anim var(--dur) cubic-bezier(0.4,0,0.2,1) infinite;
    top: 50%;
    left: 50%;
  }

  @keyframes cursor-anim {
    0%    { transform: translate(0, 0); opacity: 1; }
    5%    { transform: translate(0, 0); opacity: 1; }
    /* Arrive at browser CENTER */
    10%   { transform: translate(-99px, -118px); opacity: 1; }
    /* Single smooth drag toward top-left */
    19%   { transform: translate(-269px, -157px); opacity: 1; }
    /* Browser snaps — cursor jumps to TL quarter center */
    20%   { transform: translate(-224px, -140px); opacity: 1; }
    21%   { transform: translate(-224px, -140px); opacity: 1; }
    /* Move to terminal CENTER */
    25%   { transform: translate(-242px, 123px); opacity: 1; }
    /* Single smooth drag toward bottom-left */
    34%   { transform: translate(-287px, 155px); opacity: 1; }
    /* Terminal snaps — cursor jumps to BL quarter center */
    35%   { transform: translate(-224px, 140px); opacity: 1; }
    36%   { transform: translate(-224px, 140px); opacity: 1; }
    /* Move to editor CENTER */
    40%   { transform: translate(134px, -17px); opacity: 1; }
    /* Single smooth drag toward right half */
    49%   { transform: translate(197px, -25px); opacity: 1; }
    /* Editor snaps — cursor jumps to right-half center */
    50%   { transform: translate(224px, 0px); opacity: 1; }
    51%   { transform: translate(224px, 0px); opacity: 1; }
    /* Move to center border */
    55%   { transform: translate(0, 0); opacity: 1; }
    /* Hide for resize cursor handoff */
    56%   { transform: translate(0, 0); opacity: 0; }
    78%   { transform: translate(0, 0); opacity: 0; }
    /* Reappear at center */
    79%   { transform: translate(0, 0); opacity: 1; }
    87%   { transform: translate(0, 0); opacity: 1; }
    100%  { transform: translate(0, 0); opacity: 1; }
  }



  /* === BROWSER WINDOW animation === */
  .hero-win-browser {
    animation: browser-move var(--dur) cubic-bezier(0.4,0,0.2,1) infinite;
  }

  @keyframes browser-move {
    0%    { top: 8%; left: 20%; width: 38%; height: 42%; border-radius: 10px; }
    10%   { top: 8%; left: 20%; width: 38%; height: 42%; border-radius: 10px; }
    /* Single smooth drag — keeps original size */
    19%   { top: 1%; left: 1%; width: 38%; height: 42%; border-radius: 6px; }
    /* Snap to TL quarter */
    20%   { top: 0%; left: 0%; width: 50%; height: 50%; border-radius: 0; }
